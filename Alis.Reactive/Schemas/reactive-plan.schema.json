{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alis.reactive/schemas/reactive-plan.schema.json",
  "title": "Reactive Plan",
  "description": "The complete runtime plan serialized by ReactivePlan.Render()",
  "type": "object",
  "required": ["planId", "components", "entries"],
  "additionalProperties": false,
  "properties": {
    "planId": {
      "type": "string",
      "description": "typeof(TModel).FullName — runtime merge key"
    },
    "components": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/ComponentEntry" },
      "description": "Binding path → component registration. Shared by gather and validation."
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/Entry" }
    }
  },
  "$defs": {
    "ComponentEntry": {
      "type": "object",
      "required": ["id", "vendor", "readExpr", "componentType", "coerceAs"],
      "properties": {
        "id": { "type": "string", "description": "DOM element ID" },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "readExpr": { "type": "string", "description": "Property path from vendor root" },
        "componentType": { "type": "string", "description": "Component kind — autocomplete, dropdownlist, switch, textbox, etc." },
        "coerceAs": { "$ref": "#/$defs/CoercionType", "description": "Coercion type inferred from C# typeof(TProp)" }
      },
      "additionalProperties": false
    },
    "Entry": {
      "type": "object",
      "required": ["trigger", "reaction"],
      "additionalProperties": false,
      "properties": {
        "trigger": { "$ref": "#/$defs/Trigger" },
        "reaction": { "$ref": "#/$defs/Reaction" }
      }
    },

    "Trigger": {
      "oneOf": [
        { "$ref": "#/$defs/DomReadyTrigger" },
        { "$ref": "#/$defs/CustomEventTrigger" },
        { "$ref": "#/$defs/ComponentEventTrigger" },
        { "$ref": "#/$defs/ServerPushTrigger" },
        { "$ref": "#/$defs/SignalRTrigger" }
      ]
    },
    "DomReadyTrigger": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dom-ready" }
      }
    },
    "CustomEventTrigger": {
      "type": "object",
      "required": ["kind", "event"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "custom-event" },
        "event": { "type": "string", "minLength": 1 }
      }
    },
    "Vendor": {
      "type": "string",
      "enum": ["fusion", "native"],
      "description": "Component vendor — determines the root object for all component interactions. native→el (DOM element), fusion→el.ej2_instances[0] (Syncfusion instance). Used by reads (readExpr), events (addEventListener), and writes (bracket notation on resolved root)."
    },
    "ComponentEventTrigger": {
      "type": "object",
      "required": ["kind", "componentId", "jsEvent", "vendor"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "component-event" },
        "componentId": { "type": "string", "minLength": 1 },
        "jsEvent": { "type": "string", "minLength": 1 },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "bindingPath": { "type": "string", "minLength": 1, "description": "Dot-notation model binding path (e.g. Address.City). Carried for future HTTP gather." },
        "readExpr": { "type": "string", "minLength": 1, "description": "Property path from vendor-determined root for reading the component value in event payload. Examples: 'value', 'checked'. Runtime uses walk(el, readExpr) — plan-driven, no hardcoded property lists." }
      }
    },
    "ServerPushTrigger": {
      "type": "object",
      "required": ["kind", "url"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "server-push" },
        "url": { "type": "string", "minLength": 1, "description": "SSE endpoint URL (e.g. /api/notifications/stream)" },
        "eventType": { "type": "string", "minLength": 1, "description": "Optional SSE event type filter. Maps to the event: field in the SSE protocol." }
      }
    },
    "SignalRTrigger": {
      "type": "object",
      "required": ["kind", "hubUrl", "methodName"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "signalr" },
        "hubUrl": { "type": "string", "minLength": 1, "description": "Hub URL (e.g. /hubs/notifications). Connection shared across triggers with same hubUrl." },
        "methodName": { "type": "string", "minLength": 1, "description": "Server method name to listen for (e.g. ReceiveNotification). Maps to connection.on(methodName, handler)." }
      }
    },

    "Reaction": {
      "oneOf": [
        { "$ref": "#/$defs/SequentialReaction" },
        { "$ref": "#/$defs/ConditionalReaction" },
        { "$ref": "#/$defs/HttpReaction" },
        { "$ref": "#/$defs/ParallelHttpReaction" }
      ]
    },
    "SequentialReaction": {
      "type": "object",
      "required": ["kind", "commands"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "sequential" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        }
      }
    },

    "Command": {
      "oneOf": [
        { "$ref": "#/$defs/DispatchCommand" },
        { "$ref": "#/$defs/MutateElementCommand" },
        { "$ref": "#/$defs/MutateEventCommand" },
        { "$ref": "#/$defs/ValidationErrorsCommand" },
        { "$ref": "#/$defs/IntoCommand" }
      ]
    },
    "DispatchCommand": {
      "type": "object",
      "required": ["kind", "event"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dispatch" },
        "event": { "type": "string" },
        "payload": { "type": "object" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "BindSource": {
      "oneOf": [
        { "$ref": "#/$defs/EventSource" },
        { "$ref": "#/$defs/ComponentSource" }
      ]
    },
    "EventSource": {
      "type": "object",
      "required": ["kind", "path"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "event" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "ComponentSource": {
      "type": "object",
      "required": ["kind", "componentId", "vendor", "readExpr"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "component" },
        "componentId": { "type": "string", "minLength": 1 },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "readExpr": { "type": "string", "minLength": 1 }
      }
    },
    "BindExpr": {
      "type": "string",
      "minLength": 1,
      "description": "Dot-notation path into execution context, e.g. evt.address.city"
    },
    "CoercionType": {
      "type": "string",
      "enum": ["string", "number", "boolean", "date", "raw", "array"],
      "description": "Type coercion applied to resolved BindExpr value"
    },

    "GuardOp": {
      "type": "string",
      "enum": [
        "eq", "neq", "gt", "gte", "lt", "lte",
        "truthy", "falsy", "is-null", "not-null",
        "is-empty", "not-empty",
        "in", "not-in", "between",
        "array-contains",
        "contains", "starts-with", "ends-with", "matches", "min-length"
      ],
      "description": "Comparison operator for a ValueGuard"
    },
    "Guard": {
      "oneOf": [
        { "$ref": "#/$defs/ValueGuard" },
        { "$ref": "#/$defs/AllGuard" },
        { "$ref": "#/$defs/AnyGuard" },
        { "$ref": "#/$defs/InvertGuard" },
        { "$ref": "#/$defs/ConfirmGuard" }
      ]
    },
    "ValueGuard": {
      "type": "object",
      "required": ["kind", "source", "coerceAs", "op"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "value" },
        "source": { "$ref": "#/$defs/BindSource" },
        "coerceAs": { "$ref": "#/$defs/CoercionType" },
        "op": { "$ref": "#/$defs/GuardOp" },
        "operand": {
          "description": "Comparison value for binary operators (eq, neq, gt, etc.)"
        },
        "rightSource": {
          "$ref": "#/$defs/BindSource",
          "description": "When present, the right-hand side is a source (component or event), not a literal operand. Enables source-vs-source comparisons."
        },
        "elementCoerceAs": {
          "$ref": "#/$defs/CoercionType",
          "description": "Element-level coercion for array operators (array-contains). Specifies how to coerce individual elements and the operand."
        }
      }
    },
    "AllGuard": {
      "type": "object",
      "required": ["kind", "guards"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "all" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/Guard" },
          "minItems": 2
        }
      }
    },
    "AnyGuard": {
      "type": "object",
      "required": ["kind", "guards"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "any" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/Guard" },
          "minItems": 2
        }
      }
    },
    "InvertGuard": {
      "type": "object",
      "required": ["kind", "inner"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "not" },
        "inner": { "$ref": "#/$defs/Guard" }
      }
    },
    "ConfirmGuard": {
      "type": "object",
      "required": ["kind", "message"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "confirm" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "Branch": {
      "type": "object",
      "required": ["reaction"],
      "additionalProperties": false,
      "properties": {
        "guard": {
          "oneOf": [
            { "$ref": "#/$defs/Guard" },
            { "type": "null" }
          ]
        },
        "reaction": { "$ref": "#/$defs/Reaction" }
      }
    },
    "ConditionalReaction": {
      "type": "object",
      "required": ["kind", "branches"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "conditional" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "branches": {
          "type": "array",
          "items": { "$ref": "#/$defs/Branch" },
          "minItems": 1
        }
      }
    },
    "Mutation": {
      "oneOf": [
        { "$ref": "#/$defs/SetPropMutation" },
        { "$ref": "#/$defs/CallMutation" }
      ]
    },
    "SetPropMutation": {
      "type": "object",
      "required": ["kind", "prop"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "set-prop" },
        "prop": { "type": "string", "minLength": 1, "description": "Property name to set: root[prop] = val" },
        "coerce": { "$ref": "#/$defs/CoercionType" }
      }
    },
    "MethodArg": {
      "oneOf": [
        { "$ref": "#/$defs/LiteralArg" },
        { "$ref": "#/$defs/SourceArg" }
      ]
    },
    "LiteralArg": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "literal" },
        "value": { "description": "Literal argument value" }
      }
    },
    "SourceArg": {
      "type": "object",
      "required": ["kind", "source"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "source" },
        "source": { "$ref": "#/$defs/BindSource" },
        "coerce": { "$ref": "#/$defs/CoercionType" }
      }
    },
    "CallMutation": {
      "type": "object",
      "required": ["kind", "method"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "call" },
        "method": { "type": "string", "minLength": 1, "description": "Method to call: root[method](...args)" },
        "chain": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "$ref": "#/$defs/MethodArg" }, "description": "Per-arg resolution: each arg is literal or source-walked" }
      }
    },
    "MutateElementCommand": {
      "type": "object",
      "required": ["kind", "target", "mutation"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "mutate-element" },
        "target": { "type": "string", "minLength": 1 },
        "mutation": { "$ref": "#/$defs/Mutation" },
        "value": { "description": "Static value for mutations — string for scalars, array for multi-select" },
        "source": { "$ref": "#/$defs/BindSource" },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "GatherItem": {
      "oneOf": [
        { "$ref": "#/$defs/ComponentGather" },
        { "$ref": "#/$defs/StaticGather" },
        { "$ref": "#/$defs/AllGather" },
        { "$ref": "#/$defs/EventGather" }
      ]
    },
    "AllGather": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "const": "all" }
      },
      "additionalProperties": false
    },
    "ComponentGather": {
      "type": "object",
      "required": ["kind", "componentId", "vendor", "name", "readExpr"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "component" },
        "componentId": { "type": "string", "minLength": 1, "description": "DOM element ID of the component" },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "name": { "type": "string", "minLength": 1, "description": "Property name for the gathered value in the request body" },
        "readExpr": { "type": "string", "minLength": 1, "description": "Property path from vendor-determined root. Vendor resolves root (native→el, fusion→ej2_instances[0]), then readExpr is walked from that root. Examples: 'checked', 'value'" }
      }
    },
    "StaticGather": {
      "type": "object",
      "required": ["kind", "param", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "static" },
        "param": { "type": "string", "minLength": 1 },
        "value": { "description": "Static value to include in the request" }
      }
    },
    "EventGather": {
      "type": "object",
      "required": ["kind", "param", "path"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "event" },
        "param": { "type": "string", "minLength": 1, "description": "Query parameter or body field name" },
        "path": { "type": "string", "minLength": 1, "description": "Dot-notation path into event payload (e.g., evt.text)" }
      }
    },

    "StatusHandler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "statusCode": { "type": "integer", "description": "HTTP status code to match. Null = catch-all." },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "reaction": { "$ref": "#/$defs/Reaction", "description": "Full reaction for non-sequential handlers (conditional, http). Mutually exclusive with commands." }
      },
      "oneOf": [
        { "required": ["commands"] },
        { "required": ["reaction"] }
      ]
    },

    "RequestDescriptor": {
      "type": "object",
      "required": ["verb", "url"],
      "additionalProperties": false,
      "properties": {
        "verb": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE"] },
        "url": { "type": "string", "minLength": 1 },
        "gather": {
          "type": "array",
          "items": { "$ref": "#/$defs/GatherItem" }
        },
        "contentType": {
          "type": "string",
          "enum": ["form-data"],
          "description": "Request body format. Omitted for JSON (default). Set to form-data for multipart/form-data (file uploads)."
        },
        "whileLoading": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "onSuccess": {
          "type": "array",
          "items": { "$ref": "#/$defs/StatusHandler" }
        },
        "onError": {
          "type": "array",
          "items": { "$ref": "#/$defs/StatusHandler" }
        },
        "chained": { "$ref": "#/$defs/RequestDescriptor" },
        "validation": { "$ref": "#/$defs/ValidationDescriptor" }
      }
    },

    "HttpReaction": {
      "type": "object",
      "required": ["kind", "request"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "http" },
        "preFetch": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "request": { "$ref": "#/$defs/RequestDescriptor" }
      }
    },

    "ParallelHttpReaction": {
      "type": "object",
      "required": ["kind", "requests"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "parallel-http" },
        "preFetch": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "requests": {
          "type": "array",
          "items": { "$ref": "#/$defs/RequestDescriptor" },
          "minItems": 2
        },
        "onAllSettled": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        }
      }
    },

    "ValidationErrorsCommand": {
      "type": "object",
      "required": ["kind", "formId"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "validation-errors" },
        "formId": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },
    "MutateEventCommand": {
      "type": "object",
      "required": ["kind", "mutation"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "mutate-event" },
        "mutation": { "$ref": "#/$defs/Mutation", "description": "set-prop or call on the event args object (ctx.evt). Same mutation algebra as mutate-element." },
        "value": { "description": "Static value for set-prop mutations" },
        "source": { "$ref": "#/$defs/BindSource" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },
    "IntoCommand": {
      "type": "object",
      "required": ["kind", "target"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "into" },
        "target": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "ValidationCondition": {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1, "description": "Model property name to evaluate" },
        "op": { "type": "string", "enum": ["truthy", "falsy", "eq", "neq"] },
        "value": { "description": "Comparison value for eq/neq operators" }
      }
    },
    "ValidationRuleType": {
      "type": "string",
      "enum": ["required", "empty", "minLength", "maxLength", "email", "regex", "url",
               "creditCard", "range", "exclusiveRange", "min", "max", "gt", "lt",
               "equalTo", "notEqual", "notEqualTo", "atLeastOne"]
    },
    "ValidationRule": {
      "type": "object",
      "required": ["rule", "message"],
      "additionalProperties": false,
      "properties": {
        "rule": { "$ref": "#/$defs/ValidationRuleType" },
        "message": { "type": "string", "minLength": 1 },
        "constraint": { "description": "Rule-specific constraint value" },
        "field": { "type": "string", "minLength": 1, "description": "Cross-property: binding path of field to compare against" },
        "coerceAs": { "$ref": "#/$defs/CoercionType", "description": "Coercion type for comparison — derived from TProperty" },
        "when": { "$ref": "#/$defs/ValidationCondition" }
      }
    },
    "ValidationField": {
      "type": "object",
      "required": ["fieldName", "rules"],
      "additionalProperties": false,
      "properties": {
        "fieldName": { "type": "string", "minLength": 1, "description": "Model property name (dot notation)" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationRule" }
        },
        "fieldId": { "type": "string", "description": "DOM element ID — enriched from ComponentsMap at render time" },
        "vendor": { "$ref": "#/$defs/Vendor", "description": "Component vendor — enriched from ComponentsMap" },
        "readExpr": { "type": "string", "description": "Property path from vendor root — enriched from ComponentsMap" },
        "coerceAs": { "$ref": "#/$defs/CoercionType", "description": "Coercion type — enriched from ComponentsMap" }
      }
    },
    "ValidationDescriptor": {
      "type": "object",
      "required": ["formId", "planId", "fields"],
      "additionalProperties": false,
      "properties": {
        "formId": { "type": "string", "minLength": 1, "description": "Form container element ID" },
        "planId": { "type": "string", "minLength": 1, "description": "Plan identity — used by runtime to scope validation summary div lookup" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationField" }
        }
      }
    }
  }
}
