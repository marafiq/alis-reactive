{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alis.reactive/schemas/reactive-plan.schema.json",
  "title": "Reactive Plan",
  "description": "The complete runtime plan serialized by ReactivePlan.Render()",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/Entry" }
    }
  },
  "$defs": {
    "Entry": {
      "type": "object",
      "required": ["trigger", "reaction"],
      "additionalProperties": false,
      "properties": {
        "trigger": { "$ref": "#/$defs/Trigger" },
        "reaction": { "$ref": "#/$defs/Reaction" }
      }
    },

    "Trigger": {
      "oneOf": [
        { "$ref": "#/$defs/DomReadyTrigger" },
        { "$ref": "#/$defs/CustomEventTrigger" },
        { "$ref": "#/$defs/ComponentEventTrigger" }
      ]
    },
    "DomReadyTrigger": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dom-ready" }
      }
    },
    "CustomEventTrigger": {
      "type": "object",
      "required": ["kind", "event"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "custom-event" },
        "event": { "type": "string", "minLength": 1 }
      }
    },
    "Vendor": {
      "type": "string",
      "enum": ["fusion", "native"],
      "description": "Component vendor — determines how the runtime resolves and wires the component"
    },
    "ComponentEventTrigger": {
      "type": "object",
      "required": ["kind", "componentId", "jsEvent", "vendor"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "component-event" },
        "componentId": { "type": "string", "minLength": 1 },
        "jsEvent": { "type": "string", "minLength": 1 },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "bindingPath": { "type": "string", "minLength": 1, "description": "Dot-notation model binding path (e.g. Address.City). Carried for future HTTP gather." }
      }
    },

    "Reaction": {
      "oneOf": [
        { "$ref": "#/$defs/SequentialReaction" },
        { "$ref": "#/$defs/ConditionalReaction" },
        { "$ref": "#/$defs/HttpReaction" },
        { "$ref": "#/$defs/ParallelHttpReaction" }
      ]
    },
    "SequentialReaction": {
      "type": "object",
      "required": ["kind", "commands"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "sequential" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        }
      }
    },

    "Command": {
      "oneOf": [
        { "$ref": "#/$defs/DispatchCommand" },
        { "$ref": "#/$defs/MutateElementCommand" },
        { "$ref": "#/$defs/ValidationErrorsCommand" },
        { "$ref": "#/$defs/IntoCommand" }
      ]
    },
    "DispatchCommand": {
      "type": "object",
      "required": ["kind", "event"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dispatch" },
        "event": { "type": "string" },
        "payload": { "type": "object" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "BindSource": {
      "oneOf": [
        { "$ref": "#/$defs/EventSource" }
      ]
    },
    "EventSource": {
      "type": "object",
      "required": ["kind", "path"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "event" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "BindExpr": {
      "type": "string",
      "minLength": 1,
      "description": "Dot-notation path into execution context, e.g. evt.address.city"
    },
    "CoercionType": {
      "type": "string",
      "enum": ["string", "number", "boolean", "date", "raw"],
      "description": "Type coercion applied to resolved BindExpr value"
    },

    "GuardOp": {
      "type": "string",
      "enum": [
        "eq", "neq", "gt", "gte", "lt", "lte",
        "truthy", "falsy", "is-null", "not-null",
        "is-empty", "not-empty",
        "in", "not-in", "between",
        "contains", "starts-with", "ends-with", "matches", "min-length"
      ],
      "description": "Comparison operator for a ValueGuard"
    },
    "Guard": {
      "oneOf": [
        { "$ref": "#/$defs/ValueGuard" },
        { "$ref": "#/$defs/AllGuard" },
        { "$ref": "#/$defs/AnyGuard" },
        { "$ref": "#/$defs/InvertGuard" },
        { "$ref": "#/$defs/ConfirmGuard" }
      ]
    },
    "ValueGuard": {
      "type": "object",
      "required": ["kind", "source", "coerceAs", "op"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "value" },
        "source": { "$ref": "#/$defs/BindSource" },
        "coerceAs": { "$ref": "#/$defs/CoercionType" },
        "op": { "$ref": "#/$defs/GuardOp" },
        "operand": {
          "description": "Comparison value for binary operators (eq, neq, gt, etc.)"
        }
      }
    },
    "AllGuard": {
      "type": "object",
      "required": ["kind", "guards"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "all" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/Guard" },
          "minItems": 2
        }
      }
    },
    "AnyGuard": {
      "type": "object",
      "required": ["kind", "guards"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "any" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/Guard" },
          "minItems": 2
        }
      }
    },
    "InvertGuard": {
      "type": "object",
      "required": ["kind", "inner"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "not" },
        "inner": { "$ref": "#/$defs/Guard" }
      }
    },
    "ConfirmGuard": {
      "type": "object",
      "required": ["kind", "message"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "confirm" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "Branch": {
      "type": "object",
      "required": ["reaction"],
      "additionalProperties": false,
      "properties": {
        "guard": {
          "oneOf": [
            { "$ref": "#/$defs/Guard" },
            { "type": "null" }
          ]
        },
        "reaction": { "$ref": "#/$defs/Reaction" }
      }
    },
    "ConditionalReaction": {
      "type": "object",
      "required": ["kind", "branches"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "conditional" },
        "branches": {
          "type": "array",
          "items": { "$ref": "#/$defs/Branch" },
          "minItems": 1
        }
      }
    },
    "MutateElementCommand": {
      "type": "object",
      "required": ["kind", "target", "jsEmit"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "mutate-element" },
        "target": { "type": "string", "minLength": 1 },
        "jsEmit": { "type": "string", "minLength": 1, "description": "JavaScript expression executed on the resolved element. Variables: el (element), val (resolved value)." },
        "value": { "type": "string" },
        "source": { "$ref": "#/$defs/BindExpr" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "GatherItem": {
      "oneOf": [
        { "$ref": "#/$defs/ComponentGather" },
        { "$ref": "#/$defs/AllGather" },
        { "$ref": "#/$defs/StaticGather" }
      ]
    },
    "ComponentGather": {
      "type": "object",
      "required": ["kind", "componentId", "vendor", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "component" },
        "componentId": { "type": "string", "minLength": 1, "description": "DOM element ID of the component" },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "name": { "type": "string", "minLength": 1, "description": "Property name for the gathered value in the request body" },
        "readExpr": { "type": "string", "minLength": 1, "description": "Property path to read the value. Prefixes: el. (DOM element), comp. (vendor component instance). E.g. comp.value, el.checked" }
      }
    },
    "AllGather": {
      "type": "object",
      "required": ["kind", "formId"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "all" },
        "formId": { "type": "string", "minLength": 1, "description": "Form element ID — all fields gathered via FormData" }
      }
    },
    "StaticGather": {
      "type": "object",
      "required": ["kind", "param", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "static" },
        "param": { "type": "string", "minLength": 1 },
        "value": { "description": "Static value to include in the request" }
      }
    },

    "StatusHandler": {
      "type": "object",
      "required": ["commands"],
      "additionalProperties": false,
      "properties": {
        "statusCode": { "type": "integer", "description": "HTTP status code to match. Null = catch-all." },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        }
      }
    },

    "RequestDescriptor": {
      "type": "object",
      "required": ["verb", "url"],
      "additionalProperties": false,
      "properties": {
        "verb": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE"] },
        "url": { "type": "string", "minLength": 1 },
        "gather": {
          "type": "array",
          "items": { "$ref": "#/$defs/GatherItem" }
        },
        "contentType": {
          "type": "string",
          "enum": ["form-data"],
          "description": "Request body format. Omitted for JSON (default). Set to form-data for multipart/form-data (file uploads)."
        },
        "whileLoading": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "onSuccess": {
          "type": "array",
          "items": { "$ref": "#/$defs/StatusHandler" }
        },
        "onError": {
          "type": "array",
          "items": { "$ref": "#/$defs/StatusHandler" }
        },
        "chained": { "$ref": "#/$defs/RequestDescriptor" },
        "validation": { "$ref": "#/$defs/ValidationDescriptor" }
      }
    },

    "HttpReaction": {
      "type": "object",
      "required": ["kind", "request"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "http" },
        "preFetch": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "request": { "$ref": "#/$defs/RequestDescriptor" }
      }
    },

    "ParallelHttpReaction": {
      "type": "object",
      "required": ["kind", "requests"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "parallel-http" },
        "preFetch": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        },
        "requests": {
          "type": "array",
          "items": { "$ref": "#/$defs/RequestDescriptor" },
          "minItems": 2
        },
        "onAllSuccess": {
          "type": "array",
          "items": { "$ref": "#/$defs/StatusHandler" }
        }
      }
    },

    "ValidationErrorsCommand": {
      "type": "object",
      "required": ["kind", "formId"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "validation-errors" },
        "formId": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },
    "IntoCommand": {
      "type": "object",
      "required": ["kind", "target"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "into" },
        "target": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "ValidationCondition": {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1, "description": "Model property name to evaluate" },
        "op": { "type": "string", "enum": ["truthy", "falsy", "eq", "neq"] },
        "value": { "description": "Comparison value for eq/neq operators" }
      }
    },
    "ValidationRuleType": {
      "type": "string",
      "enum": ["required", "minLength", "maxLength", "email", "regex", "url", "range", "min", "max", "equalTo", "atLeastOne"]
    },
    "ValidationRule": {
      "type": "object",
      "required": ["rule", "message"],
      "additionalProperties": false,
      "properties": {
        "rule": { "$ref": "#/$defs/ValidationRuleType" },
        "message": { "type": "string", "minLength": 1 },
        "constraint": { "description": "Rule-specific constraint value" },
        "when": { "$ref": "#/$defs/ValidationCondition" }
      }
    },
    "ValidationField": {
      "type": "object",
      "required": ["fieldId", "fieldName", "vendor", "rules"],
      "additionalProperties": false,
      "properties": {
        "fieldId": { "type": "string", "minLength": 1, "description": "DOM element ID" },
        "fieldName": { "type": "string", "minLength": 1, "description": "Model property name (dot notation)" },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "readExpr": { "type": "string", "minLength": 1, "description": "Property path to read the field value. Prefixes: el. (DOM element), comp. (vendor component instance). Null for native inputs (uses .value/.checked)." },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationRule" }
        }
      }
    },
    "ValidationDescriptor": {
      "type": "object",
      "required": ["formId", "fields"],
      "additionalProperties": false,
      "properties": {
        "formId": { "type": "string", "minLength": 1, "description": "Form container element ID" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationField" }
        }
      }
    }
  }
}
