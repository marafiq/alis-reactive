{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alis.reactive/schemas/reactive-plan.schema.json",
  "title": "Reactive Plan",
  "description": "The complete runtime plan serialized by ReactivePlan.Render()",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/Entry" }
    }
  },
  "$defs": {
    "Entry": {
      "type": "object",
      "required": ["trigger", "reaction"],
      "additionalProperties": false,
      "properties": {
        "trigger": { "$ref": "#/$defs/Trigger" },
        "reaction": { "$ref": "#/$defs/Reaction" }
      }
    },

    "Trigger": {
      "oneOf": [
        { "$ref": "#/$defs/DomReadyTrigger" },
        { "$ref": "#/$defs/CustomEventTrigger" },
        { "$ref": "#/$defs/ComponentEventTrigger" }
      ]
    },
    "DomReadyTrigger": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dom-ready" }
      }
    },
    "CustomEventTrigger": {
      "type": "object",
      "required": ["kind", "event"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "custom-event" },
        "event": { "type": "string", "minLength": 1 }
      }
    },
    "Vendor": {
      "type": "string",
      "enum": ["fusion", "native"],
      "description": "Component vendor — determines how the runtime resolves and wires the component"
    },
    "ComponentEventTrigger": {
      "type": "object",
      "required": ["kind", "componentId", "jsEvent", "vendor"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "component-event" },
        "componentId": { "type": "string", "minLength": 1 },
        "jsEvent": { "type": "string", "minLength": 1 },
        "vendor": { "$ref": "#/$defs/Vendor" },
        "bindingPath": { "type": "string", "minLength": 1, "description": "Dot-notation model binding path (e.g. Address.City). Carried for future HTTP gather." }
      }
    },

    "Reaction": {
      "oneOf": [
        { "$ref": "#/$defs/SequentialReaction" },
        { "$ref": "#/$defs/ConditionalReaction" }
      ]
    },
    "SequentialReaction": {
      "type": "object",
      "required": ["kind", "commands"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "sequential" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/Command" }
        }
      }
    },

    "Command": {
      "oneOf": [
        { "$ref": "#/$defs/DispatchCommand" },
        { "$ref": "#/$defs/MutateElementCommand" }
      ]
    },
    "DispatchCommand": {
      "type": "object",
      "required": ["kind", "event"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dispatch" },
        "event": { "type": "string" },
        "payload": { "type": "object" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    },

    "BindSource": {
      "oneOf": [
        { "$ref": "#/$defs/EventSource" }
      ]
    },
    "EventSource": {
      "type": "object",
      "required": ["kind", "path"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "event" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "BindExpr": {
      "type": "string",
      "minLength": 1,
      "description": "Dot-notation path into execution context, e.g. evt.address.city"
    },
    "CoercionType": {
      "type": "string",
      "enum": ["string", "number", "boolean", "date", "raw"],
      "description": "Type coercion applied to resolved BindExpr value"
    },

    "GuardOp": {
      "type": "string",
      "enum": [
        "eq", "neq", "gt", "gte", "lt", "lte",
        "truthy", "falsy", "is-null", "not-null",
        "is-empty", "not-empty",
        "in", "not-in", "between",
        "contains", "starts-with", "ends-with", "matches", "min-length"
      ],
      "description": "Comparison operator for a ValueGuard"
    },
    "Guard": {
      "oneOf": [
        { "$ref": "#/$defs/ValueGuard" },
        { "$ref": "#/$defs/AllGuard" },
        { "$ref": "#/$defs/AnyGuard" },
        { "$ref": "#/$defs/InvertGuard" },
        { "$ref": "#/$defs/ConfirmGuard" }
      ]
    },
    "ValueGuard": {
      "type": "object",
      "required": ["kind", "source", "coerceAs", "op"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "value" },
        "source": { "$ref": "#/$defs/BindSource" },
        "coerceAs": { "$ref": "#/$defs/CoercionType" },
        "op": { "$ref": "#/$defs/GuardOp" },
        "operand": {
          "description": "Comparison value for binary operators (eq, neq, gt, etc.)"
        }
      }
    },
    "AllGuard": {
      "type": "object",
      "required": ["kind", "guards"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "all" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/Guard" },
          "minItems": 2
        }
      }
    },
    "AnyGuard": {
      "type": "object",
      "required": ["kind", "guards"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "any" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/$defs/Guard" },
          "minItems": 2
        }
      }
    },
    "InvertGuard": {
      "type": "object",
      "required": ["kind", "inner"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "not" },
        "inner": { "$ref": "#/$defs/Guard" }
      }
    },
    "ConfirmGuard": {
      "type": "object",
      "required": ["kind", "message"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "confirm" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "Branch": {
      "type": "object",
      "required": ["reaction"],
      "additionalProperties": false,
      "properties": {
        "guard": {
          "oneOf": [
            { "$ref": "#/$defs/Guard" },
            { "type": "null" }
          ]
        },
        "reaction": { "$ref": "#/$defs/Reaction" }
      }
    },
    "ConditionalReaction": {
      "type": "object",
      "required": ["kind", "branches"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "conditional" },
        "branches": {
          "type": "array",
          "items": { "$ref": "#/$defs/Branch" },
          "minItems": 1
        }
      }
    },
    "MutateElementCommand": {
      "type": "object",
      "required": ["kind", "target", "jsEmit"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "mutate-element" },
        "target": { "type": "string", "minLength": 1 },
        "jsEmit": { "type": "string", "minLength": 1, "description": "JavaScript expression executed on the resolved element. Variables: el (element), val (resolved value)." },
        "value": { "type": "string" },
        "source": { "$ref": "#/$defs/BindExpr" },
        "when": { "$ref": "#/$defs/Guard" }
      }
    }
  }
}
