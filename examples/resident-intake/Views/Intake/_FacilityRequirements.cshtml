@model ResidentIntakeModel
@{
    var plan = Html.ResolvePlan<ResidentIntakeModel>();
}

<native-vstack gap="Base">
    <native-heading level="H4">Facility Requirements</native-heading>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
        @{ Html.InputField(plan, m => m.RoomPreference, o => o.Required().Label("Room Preference"))
            .NativeTextBox(b => b
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                .Placeholder("e.g., Ground floor, near garden")); }

        @{ Html.InputField(plan, m => m.DepositAmount, o => o.Required().Label("Move-in Deposit ($)"))
            .NumericTextBox(b => b
                .Min(0).Step(500)); }
    </div>
</native-vstack>

@Html.EJS().ScriptManager()
@Html.RenderPlan(plan)
