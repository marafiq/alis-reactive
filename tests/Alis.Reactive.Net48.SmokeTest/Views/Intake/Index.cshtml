@model Alis.Reactive.Net48.SmokeTest.Models.ResidentIntakeModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Native.AppLevel
@using Alis.Reactive.Net48.SmokeTest.Models
@{
    ViewBag.Title = "New Resident Intake";

    var plan = Html.ReactivePlan<ResidentIntakeModel>();
    var facilities = (System.Collections.Generic.List<LookupItem>)ViewBag.Facilities;
    var careLevels = (System.Collections.Generic.List<LookupItem>)ViewBag.CareLevels;

    // ── CustomEvent: loads summary into drawer after save ──
    Html.On(plan, t => t.CustomEvent("intake-saved", pipeline =>
    {
        pipeline.Get("/Intake/Summary")
            .Gather(g => g.IncludeAll())
            .Response(r => r.OnSuccess(s =>
            {
                s.Into("alis-drawer-content");
            }));
        pipeline.Element("alis-drawer-title").SetText("Intake Summary");
        pipeline.Component<NativeDrawer>().SetSize(DrawerSize.Md);
        pipeline.Component<NativeDrawer>().Open();
    }));
}

<div class="max-w-4xl mx-auto space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-text-primary border-b-2 border-accent pb-2">New Resident Intake</h1>
        <p class="text-sm text-text-muted mt-1">Complete all sections below. Fields marked with * are required.</p>
    </div>

    <div class="bg-white border border-border rounded-lg shadow-sm">
    <div class="p-6">
        <form id="intake-form" class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">

            @* ═══════════════════════════════════════════════════════ *@
            @* PERSONAL INFORMATION                                    *@
            @* ═══════════════════════════════════════════════════════ *@
            <div class="col-span-full">
                <h3 class="text-lg font-semibold text-text-primary">Personal Information</h3>
            </div>

            @{ Html.InputField(plan, m => m.FirstName, o => o.Required().Label("First Name"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Jane")); }

            @{ Html.InputField(plan, m => m.LastName, o => o.Required().Label("Last Name"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Doe")); }

            @{ Html.InputField(plan, m => m.DateOfBirth, o => o.Required().Label("Date of Birth"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("MM/DD/YYYY")); }

            @* ═══════════════════════════════════════════════════════ *@
            @* PLACEMENT                                               *@
            @* ═══════════════════════════════════════════════════════ *@
            <div class="col-span-full mt-2">
                <h3 class="text-lg font-semibold text-text-primary">Placement</h3>
            </div>

            @{ Html.InputField(plan, m => m.FacilityId, o => o.Required().Label("Facility"))
                .NativeDropDown(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("-- Select facility --")
                    .Items(facilities.Select(f => new System.Web.Mvc.SelectListItem { Text = f.Name, Value = f.Id }))
                    .Reactive(plan, evt => evt.Changed, (args, pipeline) =>
                    {
                        // Cascade: load units + facility info + requirements
                        pipeline.Parallel(
                            a => a.Get("/Intake/Units")
                                .Gather(g => g.FromEvent(args, x => x.Value, "facilityId"))
                                .Response(r => r.OnSuccess(s => s.Into("unit-options"))),
                            b => b.Get("/Intake/FacilityInfo")
                                .Gather(g => g.FromEvent(args, x => x.Value, "facilityId"))
                                .Response(r => r.OnSuccess(s => s.Into("facility-info"))),
                            c => c.Get("/Intake/FacilityRequirements")
                                .Gather(g => g.FromEvent(args, x => x.Value, "facilityId"))
                                .Response(r => r.OnSuccess(s => s.Into("facility-requirements")))
                        );
                    })); }

            <div id="facility-info" class="col-span-full"></div>
            <div id="facility-requirements" class="col-span-full"></div>

            <div>
                <label class="block text-sm font-semibold text-text-primary mb-1">Unit</label>
                <div id="unit-options">
                    <select id="UnitId" name="UnitId" class="w-full rounded-md border border-border px-3 py-1.5 text-sm" disabled="disabled">
                        <option value="">-- Pick a facility first --</option>
                    </select>
                </div>
            </div>

            @{ Html.InputField(plan, m => m.CareLevel, o => o.Required().Label("Care Level"))
                .NativeDropDown(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("-- Select care level --")
                    .Items(careLevels.Select(c => new System.Web.Mvc.SelectListItem { Text = c.Name, Value = c.Id }))
                    .Reactive(plan, evt => evt.Changed, (args, pipeline) =>
                    {
                        // Condition: "Memory Care" → show cognitive assessment
                        pipeline.When(args, a => a.Value).Eq("memory-care")
                            .Then(t => t.Element("cognitive-section").Show())
                            .Else(e => e.Element("cognitive-section").Hide());
                    })); }

            @{ Html.InputField(plan, m => m.AdmissionDate, o => o.Required().Label("Admission Date"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("MM/DD/YYYY")); }

            @{ Html.InputField(plan, m => m.MonthlyRate, o => o.Required().Label("Monthly Rate ($)"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("e.g., 3500")); }

            <div id="cognitive-section" class="col-span-full" hidden>
                @{ Html.InputField(plan, m => m.CognitiveAssessmentDate,
                    o => o.Label("Last Cognitive Assessment"))
                    .NativeTextBox(b => b
                        .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                        .Placeholder("MM/DD/YYYY")); }
            </div>

            @* ═══════════════════════════════════════════════════════ *@
            @* MEDICAL                                                 *@
            @* ═══════════════════════════════════════════════════════ *@
            <div class="col-span-full mt-2">
                <h3 class="text-lg font-semibold text-text-primary">Medical</h3>
            </div>

            <div class="col-span-full">
                @{ Html.InputField(plan, m => m.RequiresMedicationManagement,
                    o => o.Label("Requires Medication Management"))
                    .NativeCheckBox(b => b
                        .CssClass("h-4 w-4 rounded border-border text-accent")
                        .Reactive(plan, evt => evt.Changed, (args, pipeline) =>
                        {
                            // Condition: checkbox → show/hide physician field
                            pipeline.When(args, a => a.Checked).Truthy()
                                .Then(t => t.Element("physician-section").Show())
                                .Else(e => e.Element("physician-section").Hide());
                        })); }
            </div>

            <div id="physician-section" class="col-span-full" hidden>
                @{ Html.InputField(plan, m => m.PrimaryPhysician,
                    o => o.Label("Primary Physician"))
                    .NativeTextBox(b => b
                        .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                        .Placeholder("Dr. Smith")); }
            </div>

            @* ═══════════════════════════════════════════════════════ *@
            @* EMERGENCY CONTACT                                       *@
            @* ═══════════════════════════════════════════════════════ *@
            <div class="col-span-full mt-2">
                <h3 class="text-lg font-semibold text-text-primary">Emergency Contact</h3>
            </div>

            @{ Html.InputField(plan, m => m.EmergencyContactName,
                o => o.Required().Label("Contact Name"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("John Doe")); }

            @{ Html.InputField(plan, m => m.EmergencyContactPhone,
                o => o.Required().Label("Contact Phone"))
                .NativeTextBox(b => b
                    .CssClass("w-full rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("(555) 123-4567")); }

        </form>

        @* ═══════════════════════════════════════════════════════ *@
        @* FORM ACTIONS                                            *@
        @* ═══════════════════════════════════════════════════════ *@
        <div id="form-actions" class="mt-6 flex items-center gap-3">
            @(Html.NativeButton("submit-intake", "Submit Intake")
                .CssClass("rounded-md bg-accent px-6 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, pipeline) =>
                {
                    // Confirm → POST → Success/Error → Chained confirmation #
                    pipeline.Confirm("Submit this resident intake? Please verify all information is correct.")
                        .Then(t =>
                        {
                            t.Post("/Intake/Save", g => g.IncludeAll())
                             .WhileLoading(l =>
                             {
                                 l.Component<NativeLoader>().Show();
                             })
                             .Response(r => r
                                .OnSuccess(s =>
                                {
                                    s.Component<NativeLoader>().Hide();
                                    s.Element("success-toast").Show();
                                    s.Element("post-save-section").Show();
                                    s.Element("submit-intake").Hide();
                                })
                                .OnError(400, e =>
                                {
                                    e.Component<NativeLoader>().Hide();
                                    e.Element("error-toast").Show();
                                })
                                .Chained(c => c
                                    .Get("/Intake/ConfirmationNumber")
                                    .Response(r2 => r2
                                        .OnSuccess<ConfirmationResponse>((json, s2) =>
                                        {
                                            s2.Element("confirmation-number")
                                                .SetText(json, j => j.Number);
                                        }))));
                        });
                }))
        </div>

        @* ═══════════════════════════════════════════════════════ *@
        @* TOAST NOTIFICATIONS (native, no Fusion)                  *@
        @* ═══════════════════════════════════════════════════════ *@
        <div id="success-toast" class="mt-4 p-3 rounded-lg bg-emerald-50 border border-emerald-200 text-sm text-emerald-800" hidden>
            <strong>Resident Intake</strong> &mdash; Intake submitted successfully.
        </div>
        <div id="error-toast" class="mt-4 p-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800" hidden>
            <strong>Validation Error</strong> &mdash; Please correct the highlighted fields.
        </div>

        @* ═══════════════════════════════════════════════════════ *@
        @* POST-SAVE SECTION (hidden until save succeeds)          *@
        @* ═══════════════════════════════════════════════════════ *@
        <div id="post-save-section" class="mt-6 p-4 rounded-md border border-border bg-surface-alt" hidden>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                <span class="text-sm font-medium text-text-primary">Intake Submitted</span>
            </div>
            <p class="text-sm text-text-secondary">
                Confirmation: <strong id="confirmation-number" class="text-text-primary"></strong>
            </p>
            <div class="mt-3">
                @(Html.NativeButton("view-summary", "View Summary")
                    .CssClass("rounded-md border border-border px-4 py-1.5 text-sm font-medium hover:bg-surface-alt transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, pipeline) =>
                    {
                        pipeline.Dispatch("intake-saved");
                    }))
            </div>
        </div>

    </div>
    </div>

    @* ═══════════════════════════════════════════════════════ *@
    @* PLAN JSON (developer reference)                         *@
    @* ═══════════════════════════════════════════════════════ *@
    <div class="bg-white border border-border rounded-lg shadow-sm">
    <div class="p-6">
        <h3 class="text-lg font-semibold text-text-primary mb-1">Plan JSON</h3>
        <p class="text-sm text-text-muted mb-3">
            The rendered JSON plan &mdash; this is the only contract between C# and the browser.
        </p>
        <pre class="text-xs overflow-auto max-h-96 p-3 bg-surface-alt rounded-md"><code>@Html.Raw(plan.RenderFormatted())</code></pre>
    </div>
    </div>

</div>

@Html.RenderPlan(plan)
