@model Alis.Reactive.Net48.SmokeTest.Models.SmokeTestModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Native.AppLevel
@{
    ViewBag.Title = "Smoke Test";

    var plan = Html.ReactivePlan<Alis.Reactive.Net48.SmokeTest.Models.SmokeTestModel>();

    // ── 1. DomReady → SetText + AddClass ──
    Html.On(plan, t => t.DomReady(p =>
    {
        p.Element("status").SetText("Framework loaded on net48!");
        p.Element("status").AddClass("bg-emerald-100");
    }));

    // ── 2. CustomEvent handler → Show hidden section ──
    Html.On(plan, t => t.CustomEvent("show-section", p =>
    {
        p.Element("hidden-section").Show();
        p.Element("section-status").SetText("Section visible — custom event handled.");
        p.Element("section-status").AddClass("bg-emerald-100");
    }));

    // ── 3. CustomEvent handler → Open drawer with Into() ──
    Html.On(plan, t => t.CustomEvent("open-drawer", p =>
    {
        p.Element("alis-drawer-title").SetText("Net48 Drawer");
        p.Component<NativeDrawer>().SetSize(DrawerSize.Md);
        p.Get("/Home/DrawerContent")
         .Response(r => r.OnSuccess(s => s.Into("alis-drawer-content")));
        p.Component<NativeDrawer>().Open();
    }));

    // ── 4. CustomEvent handler → Close drawer ──
    Html.On(plan, t => t.CustomEvent("close-drawer", p =>
    {
        p.Component<NativeDrawer>().Close();
    }));

    // ── 5. CustomEvent handler → Hide section ──
    Html.On(plan, t => t.CustomEvent("hide-section", p =>
    {
        p.Element("hidden-section").Hide();
        p.Element("section-status").SetText("Section hidden.");
        p.Element("section-status").RemoveClass("bg-emerald-100");
    }));
}

<h2>1. DomReady &rarr; SetText</h2>
<p>On page load, the plan sets text and adds a CSS class:</p>
<p id="status" class="p-3 rounded-lg bg-surface-alt font-mono text-sm">Waiting for DomReady...</p>

<h2>2. InputField &mdash; NativeTextBox with validation</h2>
@{ Html.InputField(plan, m => m.Name, o => o.Required().Label("Name"))
    .NativeTextBox(b => b
        .Placeholder("Enter your name")); }

@{ Html.InputField(plan, m => m.Email, o => o.Label("Email"))
    .NativeTextBox(b => b
        .Placeholder("user@example.com")); }

<h2>3. NativeButton &rarr; Show / Hide section</h2>
@(Html.NativeButton("btn-show", "Show Section")
    .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
    .Reactive(plan, evt => evt.Click, (args, p) =>
    {
        p.Dispatch("show-section");
    }))

@(Html.NativeButton("btn-hide", "Hide Section")
    .CssClass("rounded-md bg-surface-alt px-4 py-2 text-sm font-medium text-text-primary border border-border hover:bg-surface transition-colors")
    .Reactive(plan, evt => evt.Click, (args, p) =>
    {
        p.Dispatch("hide-section");
    }))

<p id="section-status" class="p-3 rounded-lg bg-surface-alt font-mono text-sm">Section hidden.</p>

<div id="hidden-section" hidden>
    <div class="p-4 bg-blue-50 rounded-lg border border-blue-200 my-2">
        <strong>Success!</strong> This section was shown by a button click &rarr; dispatch &rarr; custom event &rarr; Show().
    </div>
</div>

<h2>4. NativeDrawer &mdash; Open / Close + Into()</h2>
@(Html.NativeButton("btn-open-drawer", "Open Drawer")
    .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
    .Reactive(plan, evt => evt.Click, (args, p) =>
    {
        p.Dispatch("open-drawer");
    }))

@(Html.NativeButton("btn-close-drawer", "Close Drawer")
    .CssClass("rounded-md bg-surface-alt px-4 py-2 text-sm font-medium text-text-primary border border-border hover:bg-surface transition-colors")
    .Reactive(plan, evt => evt.Click, (args, p) =>
    {
        p.Dispatch("close-drawer");
    }))

<h2>5. Rendered Plan JSON</h2>
<p>This is the JSON contract the JS runtime executes &mdash; same schema on net48 and net10:</p>
<pre>@Html.Raw(plan.RenderFormatted())</pre>

@Html.RenderPlan(plan)
