@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.FusionDatePickerModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "FusionDatePicker";

    var plan = Html.ReactivePlan<FusionDatePickerModel>();

    // ── Section 1: Property Write (SetValue) from DomReady ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<FusionDatePicker>(m => m.AdmissionDate).SetValue(new DateTime(2026, 6, 15));
    }));

    // ── Section 2: Property Read — display current value in echo text ──

    Html.On(plan, t => t.DomReady(p =>
    {
        var comp = p.Component<FusionDatePicker>(m => m.AdmissionDate);
        p.Element("value-echo").SetText(comp.Value());
    }));
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold tracking-tight">FusionDatePicker — Full API</h1>
        <p class="mt-2 text-text-secondary">
            Exercises all supported FusionDatePicker API: property writes, property reads,
            events with typed conditions, and component-read conditions.
            Senior living domain: resident admission and discharge dates.
        </p>
    </div>

    <!-- Section 1: Property Write (SetValue) -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">1. Property Write (SetValue)</h2>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, sets admission date to 2026-06-15 via structured prop on the Syncfusion ej2 instance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.InputField(plan, m => m.AdmissionDate, o => o.Label("Admission Date"))
                .DatePicker(b => b
                    .Placeholder("Select admission date")
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("change-value").SetText(args, x => x.Value);
                    })
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.When(args, x => x.Value).NotNull()
                            .Then(t => t.Element("args-condition").SetText("date selected"))
                            .Else(e => e.Element("args-condition").SetText("no date"));
                    })
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        var comp = p.Component<FusionDatePicker>(m => m.AdmissionDate);
                        p.When(comp.Value()).NotNull()
                            .Then(then =>
                            {
                                then.Element("selected-indicator").Show();
                                then.Element("selected-indicator").SetText("admission set");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("selected-indicator").Hide();
                            });
                    })); }
        </div>
    </section>

    <!-- Section 2: Property Read — Echo Value -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">2. Property Read (Value as Source)</h2>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the admission date component's <code>value</code> property and displays it in a text element.
        </p>
        <div class="font-mono text-sm">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </section>

    <!-- Section 3: Events — Changed with typed condition -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">3. Events (Changed + Typed Condition)</h2>
        <p class="text-sm text-text-secondary mb-4">
            The admission date field wires a Changed event. Change shows the new value.
            <code>When(args, x =&gt; x.Value).NotNull()</code> tests typed event-args condition.
        </p>
        <div class="font-mono text-sm space-y-1">
            <p>Change value: <span id="change-value" class="text-text-muted">&mdash;</span></p>
            <p>Args condition: <span id="args-condition" class="text-text-muted">&mdash;</span></p>
            <p>Selected: <span id="selected-indicator" hidden class="text-emerald-600">&mdash;</span></p>
        </div>
    </section>

    <!-- Section 4: Discharge Date — Component-Read Condition -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">4. Component Value Condition (Discharge Date)</h2>
        <p class="text-sm text-text-secondary mb-4">
            Button reads discharge date via <code>When(comp.Value()).IsEmpty()</code>
            and shows a warning or confirmation.
        </p>
        @{ Html.InputField(plan, m => m.DischargeDate, o => o.Label("Discharge Date"))
            .DatePicker(b => b
                .Placeholder("Select discharge date")); }
        <div class="mt-3">
            @(Html.NativeButton("check-discharge-btn", "Check Discharge Date")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    var comp = p.Component<FusionDatePicker>(m => m.DischargeDate);
                    p.When(comp.Value()).IsEmpty()
                        .Then(t => t.Element("discharge-warning").SetText("discharge date is required"))
                        .Else(e => e.Element("discharge-warning").SetText("discharge date set"));
                }))
        </div>
        <div class="font-mono text-sm mt-2">
            <p>Warning: <span id="discharge-warning" class="text-text-muted">&mdash;</span></p>
        </div>
    </section>

    <!-- Plan JSON -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">Plan JSON</h2>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </section>
</div>

@Html.RenderPlan(plan)
