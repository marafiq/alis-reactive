@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.DropDownListModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@using Alis.Reactive.Fusion.Extensions
@{
    ViewData["Title"] = "DropDownList";

    var plan = Html.ReactivePlan<DropDownListModel>();
    var categories = (List<string>)ViewBag.Categories;

    // ── Section 1: Property Write (SetValue) from DomReady ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<FusionDropDownList>(m => m.Category).SetValue("Books");
    }));

    // ── Section 2: Property Read — display current value in echo text ──

    Html.On(plan, t => t.DomReady(p =>
    {
        var comp = p.Component<FusionDropDownList>(m => m.Category);
        p.Element("value-echo").SetText(comp.Value());
    }));

    // ── Section 5: Gather — POST with Include ──

    Html.On(plan, t => t.CustomEvent("do-gather", p =>
    {
        p.Post("/Sandbox/DropDownList/Echo", g =>
            g.Include<FusionDropDownList, DropDownListModel>(m => m.Category))
         .Response(r => r
            .OnSuccess(s =>
            {
                s.Element("gather-result").SetText("gathered");
            }));
    }));
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold tracking-tight">FusionDropDownList — Full API</h1>
        <p class="mt-2 text-text-secondary">
            Exercises all supported FusionDropDownList API: property writes, method calls,
            property reads, events, conditions, and gather.
        </p>
    </div>

    <!-- Section 1: Property Write (SetValue) -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">1. Property Write (SetValue)</h2>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, sets value="Books" via structured prop on the Syncfusion ej2 instance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.Field("Category (SF DropDownList)", false, m => m.Category, expr =>
                Html.DropDownListFor(plan, expr)
                    .DataSource(categories)
                    .Placeholder("Select a category")
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("change-value").SetText(args, x => x.Value);
                    })
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.When(args, x => x.Value).Eq("Electronics")
                            .Then(t => t.Element("args-condition").SetText("electronics selected"))
                            .Else(e => e.Element("args-condition").SetText("other category"));
                    })
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        var comp = p.Component<FusionDropDownList>(m => m.Category);
                        p.When(comp.Value()).NotNull()
                            .Then(then =>
                            {
                                then.Element("selected-indicator").Show();
                                then.Element("selected-indicator").SetText("selected");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("selected-indicator").Hide();
                            });
                    })
                    .Reactive(plan, evt => evt.Focus, (args, p) =>
                    {
                        p.Element("focus-state").SetText("focused");
                    })
                    .Reactive(plan, evt => evt.Blur, (args, p) =>
                    {
                        p.Element("focus-state").SetText("blurred");
                    })
                    .Render()); }
        </div>
    </section>

    <!-- Section 2: Property Read — Echo Value -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">2. Property Read (Value as Source)</h2>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the Category component's <code>value</code> property and displays it in a text element.
        </p>
        <div class="font-mono text-sm">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </section>

    <!-- Section 3: Method Calls (ShowPopup / HidePopup) -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">3. Method Calls (ShowPopup / HidePopup)</h2>
        <p class="text-sm text-text-secondary mb-4">
            Buttons invoke <code>el.showPopup()</code> and <code>el.hidePopup()</code> on the Syncfusion instance.
        </p>
        <div class="flex gap-2 mb-3">
            @(Html.NativeButton("show-popup-btn", "Show Popup")
                .CssClass("rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionDropDownList>(m => m.Category).ShowPopup();
                }))
            @(Html.NativeButton("hide-popup-btn", "Hide Popup")
                .CssClass("rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionDropDownList>(m => m.Category).HidePopup();
                }))
        </div>
    </section>

    <!-- Section 4: Events — Changed, Focus, Blur -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">4. Events (Changed, Focus, Blur)</h2>
        <p class="text-sm text-text-secondary mb-4">
            The Category field wires all three events. Change shows the new value,
            Focus/Blur show focus state.
        </p>
        <div class="font-mono text-sm space-y-1">
            <p>Change value: <span id="change-value" class="text-text-muted">&mdash;</span></p>
            <p>Args condition: <span id="args-condition" class="text-text-muted">&mdash;</span></p>
            <p>Focus state: <span id="focus-state" class="text-text-muted">&mdash;</span></p>
            <p>Selected: <span id="selected-indicator" hidden class="text-emerald-600">&mdash;</span></p>
        </div>
    </section>

    <!-- Section 5: Conditions — Typed Event-Args + Component-Read -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">5. Conditions (Both Types)</h2>
        <p class="text-sm text-text-secondary mb-4">
            Two condition types are exercised:
            <code>When(args, x =&gt; x.Value).Eq("Electronics")</code> (typed event-args condition)
            and <code>When(comp.Value()).NotNull()</code> (component-read condition).
        </p>
    </section>

    <!-- Section 6: Gather — Include in POST -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">6. Gather (Include in POST)</h2>
        <p class="text-sm text-text-secondary mb-4">
            Click to POST the Category value gathered from the Syncfusion component via
            <code>Include&lt;FusionDropDownList&gt;</code>.
        </p>
        @(Html.NativeButton("gather-btn", "Gather Category")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors mb-3")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Dispatch("do-gather");
            }))
        <div class="font-mono text-sm">
            <p>Gather result: <span id="gather-result" class="text-text-muted">not gathered</span></p>
        </div>
    </section>

    <!-- Plan JSON -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">Plan JSON</h2>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </section>
</div>

@Html.RenderPlan(plan)
