@model TestWidgetModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@using Alis.Reactive.Fusion.Extensions
@{
    ViewData["Title"] = "TestWidget";

    var plan = Html.ReactivePlan<TestWidgetModel>();

    // ── 1: Property Write (static) ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<TestWidgetSyncFusion>("tw-write").SetValue("initialized");
    }));

    // ── 5: Component Read → Element ──

    Html.On(plan, t => t.DomReady(p =>
    {
        var comp = p.Component<TestWidgetSyncFusion>("tw-read");
        p.Element("read-echo").SetText(comp.Value());
    }));

    // ── 7: SetItems from event payload expression ──

    Html.On(plan, t => t.CustomEvent<DataSourceResponse>("load-items", (payload, p) =>
    {
        p.Component<TestWidgetSyncFusion>("tw-items")
         .SetItems(payload, x => x.Items); // make sure ts doe show array somewhere
    }));

    // ── 9: Gather → HTTP Echo ──

    Html.On(plan, t => t.CustomEvent("do-gather", p =>
    {
        p.Post("/Sandbox/AllModulesTogether/TestWidget/Echo", g =>
            g.Include<TestWidgetSyncFusion, TestWidgetModel>("tw-gather", "widgetVal"))
         .Response(r => r
            .OnSuccess(s => { s.Element("gather-result").SetText("gathered"); }));
    }));

    // ── 10-11: DataSource — wired directly on button click, no dispatch ──
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">TestWidget — Structured Mutation API Surface</native-heading>
    </div>

    <!-- 1: Property Write (static) -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">1. Property Write (Static)</native-heading>
        @(Html.TestWidget("tw-write")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full bg-gray-50"))
    </native-card-body>
    </native-card>

    <!-- 2: Void Method — Clear -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">2. Void Method — Clear</native-heading>
        @(Html.TestWidget("tw-clear")
            .InitialValue("clear-me")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        <div class="mt-3">
            @(Html.NativeButton("btn-clear", "Clear")
                .CssClass("rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<TestWidgetSyncFusion>("tw-clear").Clear().Focus();
                }))
        </div>
    </native-card-body>
    </native-card>

    <!-- 3: Void Method — Focus -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">3. Void Method — Focus</native-heading>
        @(Html.TestWidget("tw-focus")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        <div class="mt-3">
            @(Html.NativeButton("btn-focus", "Focus")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<TestWidgetSyncFusion>("tw-focus").Focus();
                }))
        </div>
    </native-card-body>
    </native-card>

    <!-- 4: Event Payload → Component (SetValue from args) -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">4. Event Payload → Component SetValue</native-heading>
        @(Html.TestWidget("tw-event-write")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
            .Reactive(plan, evt => evt.Changed, (args, p) =>
            {
                p.Component<TestWidgetSyncFusion>("tw-event-mirror")
                 .SetValue(args, a => a.NewValue);
            }))
        <div class="mt-3">
            <label class="block text-sm font-medium mb-1">Mirror (receives value)</label>
            @(Html.TestWidget("tw-event-mirror")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full bg-gray-50"))
        </div>
    </native-card-body>
    </native-card>

    <!-- 5: Component Read → Display -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">5. Component Read → Display</native-heading>
        @(Html.TestWidget("tw-read")
            .InitialValue("read-me")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full bg-gray-50"))
        <p class="mt-3 font-mono text-sm">Read: <span id="read-echo" class="text-text-muted">&mdash;</span></p>
    </native-card-body>
    </native-card>

    <!-- 6: Component Value Condition -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">6. Component Value Condition</native-heading>
        @(Html.TestWidget("tw-comp-cond")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
            .Reactive(plan, evt => evt.Changed, (args, p) =>
            {
                var comp = p.Component<TestWidgetSyncFusion>("tw-comp-cond");
                p.When(comp.Value()).NotEmpty()
                    .Then(t => { t.Element("comp-cond-ind").Show(); t.Element("comp-cond-ind").SetText("has value"); })
                    .Else(e => { e.Element("comp-cond-ind").Hide(); });
            }))
        <div id="comp-cond-ind" hidden class="mt-3 rounded-md bg-blue-50 border border-blue-200 p-4 text-sm">&mdash;</div>
    </native-card-body>
    </native-card>

    <!-- 7: Method + Arg (SetItems from event) -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">7. Method + Arg (SetItems)</native-heading>
        @(Html.TestWidget("tw-items")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full bg-gray-50"))
        <div class="mt-3">
            @(Html.NativeButton("btn-load-items", "Load Items")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Dispatch("load-items", new DataSourceResponse { Items = new[] { "x", "y", "z" } });
                }))
        </div>
    </native-card-body>
    </native-card>

    <!-- 8: Cross-Component Read → Write -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">8. Cross-Component Read → Write</native-heading>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium mb-1">Source</label>
                @(Html.TestWidget("tw-source")
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        var source = p.Component<TestWidgetSyncFusion>("tw-source");
                        p.Component<TestWidgetSyncFusion>("tw-target").SetValue(source.Value());
                    }))
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Target</label>
                @(Html.TestWidget("tw-target")
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full bg-gray-50"))
            </div>
        </div>
    </native-card-body>
    </native-card>

    <!-- 9: Gather → HTTP Echo -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">9. Gather → HTTP Echo</native-heading>
        @(Html.TestWidget("tw-gather")
            .InitialValue("gather-me")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        <div class="mt-3">
            @(Html.NativeButton("btn-gather", "Gather & POST")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white")
                .Reactive(plan, evt => evt.Click, (args, p) => { p.Dispatch("do-gather"); }))
        </div>
        <p class="mt-3 font-mono text-sm">Result: <span id="gather-result" class="text-text-muted">not gathered</span></p>
    </native-card-body>
    </native-card>

    <!-- 10-11: DataSource — Response Body → Component -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">10–11. Response Body → Component</native-heading>
        @(Html.TestWidget("tw-ds-target")
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full bg-gray-50"))
        <div class="mt-3">
            @(Html.NativeButton("btn-datasource", "Fetch DataSource")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Get("/Sandbox/AllModulesTogether/TestWidget/DataSource")
                     .Response(r => r
                        .OnSuccess<DataSourceResponse>((json, s) =>
                        {
                            s.Component<TestWidgetSyncFusion>("tw-ds-target")
                             .SetValue(json, x => x.Selected);
                            s.Component<TestWidgetSyncFusion>("tw-ds-target")
                             .SetItems(json, x => x.Items); // make sure ts doe show array somewhere
                            
                            
                        }));
                }))
        </div>
    </native-card-body>
    </native-card>

    <!-- Plan JSON -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body>
    </native-card>
</native-vstack>

@section Scripts {
    <script src="~/js/test-widget.js" asp-append-version="true"></script>
}

@Html.RenderPlan(plan)
