@model TestWidgetModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "TestWidget";

    var plan = Html.ReactivePlan<TestWidgetModel>();

    // ── Section 1: Property Write (static) — DomReady sets "initialized" ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<TestWidgetSyncFusion>("tw-write").SetValue("initialized");
    }));

    // ── Section 2: Clear + Focus chain — button clears then focuses ──

    // (wired via button .Reactive below)

    // ── Section 3: Focus — button focuses widget ──

    // (wired via button .Reactive below)

    // ── Section 4: Event Payload → Component SetValue ──

    var twEventWrite = Html.TestWidget<TestWidgetModel>("tw-event-write")
        .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
        .Reactive(plan, evt => evt.Changed, (args, p) =>
        {
            p.Component<TestWidgetSyncFusion>("tw-event-mirror").SetValue(args, x => x.NewValue);
        });

    // ── Section 5: Component Read → Display ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Element("read-echo").SetText(p.Component<TestWidgetSyncFusion>("tw-read").Value());
    }));

    // ── Section 6: Component Value Condition ──

    var twCompCond = Html.TestWidget<TestWidgetModel>("tw-comp-cond")
        .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
        .Reactive(plan, evt => evt.Changed, (args, p) =>
        {
            p.When(p.Component<TestWidgetSyncFusion>("tw-comp-cond").Value()).NotEmpty()
                .Then(t =>
                {
                    t.Element("comp-cond-ind").Show();
                    t.Element("comp-cond-ind").SetText("has value");
                })
                .Else(e =>
                {
                    e.Element("comp-cond-ind").Hide();
                });
        });

    // ── Section 7: SetItems from event dispatch ──

    Html.On(plan, t => t.CustomEvent<TestWidgetItemsPayload>("load-items", (args, p) =>
    {
        p.Component<TestWidgetSyncFusion>("tw-items").SetItems(args, x => x.Items);
    }));

    // ── Section 8: Cross-Component Read → Write ──

    var twSource = Html.TestWidget<TestWidgetModel>("tw-source")
        .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
        .Reactive(plan, evt => evt.Changed, (args, p) =>
        {
            p.Component<TestWidgetSyncFusion>("tw-target").SetValue(args, x => x.NewValue);
        });

    // ── Section 9: Gather → HTTP Echo ──

    Html.On(plan, t => t.CustomEvent("do-gather", p =>
    {
        p.Post("/Sandbox/AllModulesTogether/TestWidget/Echo", g =>
            g.Include<TestWidgetSyncFusion, TestWidgetModel>("tw-gather", "widgetVal"))
         .Response(r => r
            .OnSuccess(s =>
            {
                s.Element("gather-result").SetText("gathered");
            }));
    }));

    // ── Section 10: Response Body → SetValue + SetItems ──

    Html.On(plan, t => t.CustomEvent("do-datasource", p =>
    {
        p.Get("/Sandbox/AllModulesTogether/TestWidget/DataSource")
         .Response(r => r
            .OnSuccess<TestWidgetDataSourceResponse>((json, s) =>
            {
                s.Component<TestWidgetSyncFusion>("tw-ds-target").SetValue(json, x => x.Value);
                s.Component<TestWidgetSyncFusion>("tw-ds-target").SetItems(json, x => x.Items);
            }));
    }));
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">TestWidget — Component API Verification</native-heading>
        <native-text color="Secondary">
            Exercises every TestWidget API through the framework DSL.
        </native-text>
    </div>

    <!-- Section 1: Property Write -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Property Write (DomReady)</native-heading>
        <div>
            <label class="block text-sm font-medium mb-1">SetValue("initialized")</label>
            @(Html.TestWidget<TestWidgetModel>("tw-write")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
    </native-card-body></native-card>

    <!-- Section 2: Clear + Focus Chain -->
    <native-card><native-card-body>
        <native-heading level="H2">2. Void Method — Clear + Focus</native-heading>
        <div class="mb-3">
            <label class="block text-sm font-medium mb-1">InitialValue("clear-me")</label>
            @(Html.TestWidget<TestWidgetModel>("tw-clear")
                .InitialValue("clear-me")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
        @(Html.NativeButton("btn-clear", "Clear + Focus")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Component<TestWidgetSyncFusion>("tw-clear").Clear();
                p.Component<TestWidgetSyncFusion>("tw-clear").Focus();
            }))
    </native-card-body></native-card>

    <!-- Section 3: Focus -->
    <native-card><native-card-body>
        <native-heading level="H2">3. Void Method — Focus</native-heading>
        <div class="mb-3">
            @(Html.TestWidget<TestWidgetModel>("tw-focus")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
        @(Html.NativeButton("btn-focus", "Focus Widget")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Component<TestWidgetSyncFusion>("tw-focus").Focus();
            }))
    </native-card-body></native-card>

    <!-- Section 4: Event Payload → SetValue -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Event Payload → Component SetValue</native-heading>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium mb-1">Source (type here)</label>
                @twEventWrite
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Mirror (receives value)</label>
                @(Html.TestWidget<TestWidgetModel>("tw-event-mirror")
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
            </div>
        </div>
    </native-card-body></native-card>

    <!-- Section 5: Component Read → Display -->
    <native-card><native-card-body>
        <native-heading level="H2">5. Component Read → Display</native-heading>
        <div class="mb-3">
            <label class="block text-sm font-medium mb-1">InitialValue("read-me")</label>
            @(Html.TestWidget<TestWidgetModel>("tw-read")
                .InitialValue("read-me")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
        <p class="font-mono text-sm">Read value: <span id="read-echo" class="text-text-muted">&mdash;</span></p>
    </native-card-body></native-card>

    <!-- Section 6: Component Value Condition -->
    <native-card><native-card-body>
        <native-heading level="H2">6. Component Value Condition</native-heading>
        <div class="mb-3">
            <label class="block text-sm font-medium mb-1">Type to show/clear to hide</label>
            @twCompCond
        </div>
        <p id="comp-cond-ind" hidden class="font-mono text-sm text-green-600">&mdash;</p>
    </native-card-body></native-card>

    <!-- Section 7: SetItems from dispatch -->
    <native-card><native-card-body>
        <native-heading level="H2">7. Method + Arg — SetItems</native-heading>
        <div class="mb-3">
            @(Html.TestWidget<TestWidgetModel>("tw-items")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
        @(Html.NativeButton("btn-load-items", "Load Items")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Dispatch("load-items", new { items = new[] { "x", "y", "z" } });
            }))
    </native-card-body></native-card>

    <!-- Section 8: Cross-Component Read → Write -->
    <native-card><native-card-body>
        <native-heading level="H2">8. Cross-Component Read → Write</native-heading>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium mb-1">Source</label>
                @twSource
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Target (synced)</label>
                @(Html.TestWidget<TestWidgetModel>("tw-target")
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
            </div>
        </div>
    </native-card-body></native-card>

    <!-- Section 9: Gather → HTTP Echo -->
    <native-card><native-card-body>
        <native-heading level="H2">9. Gather → HTTP Echo</native-heading>
        <div class="mb-3">
            <label class="block text-sm font-medium mb-1">Widget to gather</label>
            @(Html.TestWidget<TestWidgetModel>("tw-gather")
                .InitialValue("gather-me")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
        @(Html.NativeButton("btn-gather", "Gather")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors mb-3")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Dispatch("do-gather");
            }))
        <p class="font-mono text-sm">Result: <span id="gather-result" class="text-text-muted">not gathered</span></p>
    </native-card-body></native-card>

    <!-- Section 10: Response Body → SetValue + SetItems -->
    <native-card><native-card-body>
        <native-heading level="H2">10. Response Body → SetValue + SetItems</native-heading>
        <div class="mb-3">
            @(Html.TestWidget<TestWidgetModel>("tw-ds-target")
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full"))
        </div>
        @(Html.NativeButton("btn-datasource", "Fetch DataSource")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Dispatch("do-datasource");
            }))
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@section Scripts {
    <script src="~/js/test-widget.js" asp-append-version="true"></script>
}

@Html.RenderPlan(plan)
