@{
    var current = (int)ViewBag.CurrentStep;
    var screeningId = (string)ViewBag.ScreeningId;
}

<native-card><native-card-body>
    <div class="flex items-center justify-between text-sm">
        <span class="@(current == 1 ? "font-bold text-accent" : "text-text-muted")">1. Demographics</span>
        <span class="text-text-muted">&rarr;</span>
        <span class="@(current == 2 ? "font-bold text-accent" : "text-text-muted")">2. Clinical</span>
        <span class="text-text-muted">&rarr;</span>
        <span class="@(current == 3 ? "font-bold text-accent" : "text-text-muted")">3. Functional</span>
        <span class="text-text-muted">&rarr;</span>
        <span class="@(current == 4 ? "font-bold text-accent" : "text-text-muted")">4. Review</span>
    </div>
</native-card-body></native-card>
