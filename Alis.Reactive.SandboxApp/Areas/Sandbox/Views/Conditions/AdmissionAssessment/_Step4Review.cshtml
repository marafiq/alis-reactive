@model Step4ReviewModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    var plan = Html.ReactivePlan<Step4ReviewModel>();
}

<!-- ASSERT: empty EmergencyContact → contact-warning visible
     ASSERT: fill EmergencyContact → contact-warning hidden
     ASSERT: submit with empty contact → validation error on screening-form
     ASSERT: submit with valid data → submit-result shows message -->
<native-card><native-card-body id="screening-form">
    <native-heading level="H2">Step 4: Review &amp; Submit</native-heading>
    <p class="text-sm text-text-secondary mb-4">
        Review the assessment summary and provide emergency contact before final submission.
    </p>

    <!-- Hidden fields: cross-step summary data -->
    @Html.HiddenFieldFor(plan, m => m.ScreeningId)
    @Html.HiddenFieldFor(plan, m => m.RiskTier)
    @Html.HiddenFieldFor(plan, m => m.CareUnit)
    @Html.HiddenFieldFor(plan, m => m.MonitoringLevel)

    <!-- Emergency Contact -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        @{ Html.InputField(plan, m => m.EmergencyContact, o => o.Required().Label("Emergency Contact"))
            .NativeTextBox(b => b
                .Placeholder("Full name and phone number")
                .Reactive(plan, evt => evt.Changed, (args, p) =>
                {
                    var contact = p.Component<NativeTextBox>(m => m.EmergencyContact);
                    p.When(contact.Value()).IsEmpty()
                        .Then(t => t.Element("contact-warning").Show())
                        .Else(e => e.Element("contact-warning").Hide());
                })); }
    </div>

    <div id="contact-warning" hidden class="rounded-md bg-amber-50 border border-amber-200 px-3 py-2 text-sm text-amber-700 mb-4">
        Emergency contact is required before submission.
    </div>

    <!-- Summary Panel -->
    <native-card>
        <native-card-body>
            <native-heading level="H3">Assessment Summary</native-heading>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-3">
                <div>
                    <p class="text-xs text-text-muted uppercase tracking-wider">Risk Tier</p>
                    <p class="text-sm font-semibold"><span id="summary-risk-tier">@Model.RiskTier</span></p>
                </div>
                <div>
                    <p class="text-xs text-text-muted uppercase tracking-wider">Care Unit</p>
                    <p class="text-sm font-semibold"><span id="summary-care-unit">@Model.CareUnit</span></p>
                </div>
                <div>
                    <p class="text-xs text-text-muted uppercase tracking-wider">Monitoring Level</p>
                    <p class="text-sm font-semibold"><span id="summary-monitoring-level">@Model.MonitoringLevel</span></p>
                </div>
            </div>
        </native-card-body>
    </native-card>

    <!-- Submit Result -->
    <div id="submit-result" hidden class="rounded-md bg-emerald-50 border border-emerald-200 px-3 py-2 text-sm text-emerald-700 mt-4"></div>

    <!-- Step 4 Navigation + Submit -->
    <div class="flex justify-between mt-6">
        @(Html.NativeButton("prev-4", "\u2190 Back: Functional")
            .CssClass("rounded-md border border-border px-6 py-2 text-sm font-medium text-text-primary hover:bg-slate-50 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Element("step-4").Hide();
                p.Element("step-3").Show();
                p.Element("step-ind-4").RemoveClass("font-bold");
                p.Element("step-ind-4").RemoveClass("text-accent");
                p.Element("step-ind-3").AddClass("font-bold");
                p.Element("step-ind-3").AddClass("text-accent");
            }))
        @(Html.NativeButton("submit-btn", "Submit Assessment")
            .CssClass("rounded-md bg-accent px-6 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Element("submit-spinner").Show();
                p.Element("submit-text").Hide();
                p.Post("/Sandbox/Conditions/AdmissionAssessment/Submit",
                    g => g.IncludeAll())
                 .Validate<Step4Validator>("screening-form")
                 .Response(r => r
                    .OnSuccess<SubmitScreeningResponse>((json, s) =>
                    {
                        s.Element("submit-result").SetText(json, x => x.Message);
                        s.Element("submit-result").Show();
                        s.Element("submit-spinner").Hide();
                        s.Element("submit-text").Show();
                    })
                    .OnError(400, e =>
                    {
                        e.ValidationErrors("screening-form");
                        e.Element("submit-spinner").Hide();
                        e.Element("submit-text").Show();
                    }));
            }))
    </div>
    <div class="font-mono text-sm mt-2">
        <span id="submit-spinner" hidden class="text-accent">Submitting...</span>
        <span id="submit-text"></span>
    </div>
</native-card-body></native-card>

@Html.RenderPlan(plan)
