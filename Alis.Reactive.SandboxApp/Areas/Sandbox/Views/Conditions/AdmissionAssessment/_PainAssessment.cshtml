@model Step3FunctionalModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    var plan = Html.ResolvePlan<Step3FunctionalModel>();
}

<native-card><native-card-body>
    <native-heading level="H3">Pain Assessment</native-heading>
    <p class="text-sm text-text-secondary mb-4">
        Pain level above 7 triggers a pain management alert and requires pain location.
    </p>

    <!-- Row 1: Pain Level + Pain Location -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        @{ Html.InputField(plan, m => m.PainLevel, o => o.Label("Pain Level (0-10)"))
            .FusionNumericTextBox(b => b
                .Min(0).Max(10).Step(1)
                .Reactive(plan, evt => evt.Changed, (args, p) =>
                {
                    var comp = p.Component<FusionNumericTextBox>(m => m.PainLevel);
                    p.Element("pain-echo").SetText(comp.Value());

                    p.When(comp.Value()).Gt(7m)
                        .Then(then =>
                        {
                            then.Element("pain-spinner").Show();
                            then.Element("location-required").Show();
                            then.Post("/Sandbox/Conditions/AdmissionAssessment/AlertPain",
                                g => g.Include<FusionNumericTextBox, Step3FunctionalModel>(m => m.PainLevel)
                                      .Include<NativeTextBox, Step3FunctionalModel>(m => m.PainLocation))
                             .Response(r => r.OnSuccess<ScreeningAlertResponse>((json, s) =>
                             {
                                 s.Element("pain-result").SetText(json, x => x.Message);
                                 s.Element("pain-result").Show();
                                 s.Element("pain-spinner").Hide();
                             }));
                        })
                        .Else(e =>
                        {
                            e.Element("location-required").Hide();
                            e.Element("pain-result").Hide();
                        });
                })); }

        @{ Html.InputField(plan, m => m.PainLocation, o => o.Label("Pain Location"))
            .NativeTextBox(b => b.Placeholder("e.g. Lower back, left knee")); }
    </div>

    <!-- Status echoes -->
    <div class="font-mono text-sm space-y-1">
        <p>Pain level: <span id="pain-echo" class="text-text-muted">&mdash;</span></p>
        <p><span id="pain-spinner" hidden class="text-accent">Sending alert...</span></p>
        <div id="location-required" hidden class="rounded-md bg-amber-50 border border-amber-200 px-3 py-2 text-sm text-amber-700">
            Pain location is required for pain levels above 7.
        </div>
        <div id="pain-result" hidden class="rounded-md bg-rose-50 border border-rose-200 px-3 py-2 text-sm text-rose-700 mt-2"></div>
    </div>
</native-card-body></native-card>

@Html.RenderPlan(plan)
