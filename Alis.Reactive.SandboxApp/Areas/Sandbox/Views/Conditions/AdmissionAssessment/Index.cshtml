@model HealthScreeningModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "Admission Assessment";

    var plan = Html.ReactivePlan<HealthScreeningModel>();

    var diagnoses = (string[])ViewBag.Diagnoses;
    var fallOptions = (string[])ViewBag.FallOptions;
    var mobilityAids = (string[])ViewBag.MobilityAids;
    var serviceBranches = (string[])ViewBag.ServiceBranches;
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">Admission Assessment</native-heading>
        <native-text color="Secondary">
            Multi-step health screening workflow with conditional clinical sections,
            server-side physician search, and condition-gated alerts.
        </native-text>
    </div>

    <!-- Step Indicator -->
    <native-card><native-card-body>
        <div class="flex items-center justify-between text-sm">
            <span id="step-ind-1" class="font-bold text-accent">1. Demographics</span>
            <span class="text-text-muted">&rarr;</span>
            <span id="step-ind-2" class="text-text-muted">2. Clinical</span>
            <span class="text-text-muted">&rarr;</span>
            <span id="step-ind-3" class="text-text-muted">3. Functional</span>
            <span class="text-text-muted">&rarr;</span>
            <span id="step-ind-4" class="text-text-muted">4. Review</span>
        </div>
    </native-card-body></native-card>

    <!-- Hidden Fields -->
    @Html.HiddenFieldFor(plan, m => m.CognitiveAssessmentId)
    @Html.HiddenFieldFor(plan, m => m.CardiacAssessmentId)
    @Html.HiddenFieldFor(plan, m => m.DiabetesAssessmentId)
    @Html.HiddenFieldFor(plan, m => m.CareUnit)
    @Html.HiddenFieldFor(plan, m => m.MonitoringLevel)

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Step 1: Demographics                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div id="step-1">
        <native-card><native-card-body>
            <native-heading level="H2">Step 1: Demographics</native-heading>
            <p class="text-sm text-text-secondary mb-4">
                Basic resident information. Age auto-calculates risk tier. Diagnosis determines which clinical sections appear in Step 2.
            </p>

            <!-- Row 1: Resident Name + Age -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.ResidentName, o => o.Required().Label("Resident Name"))
                    .NativeTextBox(b => b.Placeholder("Full name")); }

                @{ Html.InputField(plan, m => m.Age, o => o.Required().Label("Age"))
                    .NumericTextBox(b => b
                        .Min(0).Max(120).Step(1)
                        .Reactive(plan, evt => evt.Changed, (args, p) =>
                        {
                            var ageComp = p.Component<FusionNumericTextBox>(m => m.Age);
                            p.Element("age-echo").SetText(ageComp.Value());

                            p.When(ageComp.Value()).Gte(85m)
                                .Then(t =>
                                {
                                    t.Component<FusionDropDownList>(m => m.RiskTier).SetValue("High");
                                    t.Element("risk-badge").SetText("High Risk");
                                    t.Element("risk-badge").Show();
                                })
                                .ElseIf(ageComp.Value()).Gte(65m)
                                .Then(t =>
                                {
                                    t.Component<FusionDropDownList>(m => m.RiskTier).SetValue("Standard");
                                    t.Element("risk-badge").SetText("Standard Risk");
                                    t.Element("risk-badge").Show();
                                })
                                .Else(e =>
                                {
                                    e.Component<FusionDropDownList>(m => m.RiskTier).SetValue("Low");
                                    e.Element("risk-badge").SetText("Low Risk");
                                    e.Element("risk-badge").Show();
                                });

                            p.Element("age-status").SetText("assessed");
                        })); }
            </div>

            <!-- Row 2: Primary Diagnosis + Attending Physician -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.PrimaryDiagnosis, o => o.Required().Label("Primary Diagnosis"))
                    .DropDownList(b => b
                        .DataSource(diagnoses)
                        .Placeholder("Select diagnosis")
                        .Reactive(plan, evt => evt.Changed, (args, p) =>
                        {
                            var diag = p.Component<FusionDropDownList>(m => m.PrimaryDiagnosis);

                            p.When(diag.Value()).In("Alzheimer's", "Parkinson's")
                                .Then(t => t.Element("cognitive-section").Show())
                                .Else(e => e.Element("cognitive-section").Hide());

                            p.When(diag.Value()).Eq("Heart Disease")
                                .Then(t => t.Element("cardiac-section").Show())
                                .Else(e => e.Element("cardiac-section").Hide());

                            p.When(diag.Value()).Eq("Diabetes")
                                .Then(t => t.Element("diabetes-section").Show())
                                .Else(e => e.Element("diabetes-section").Hide());
                        })); }

                @{ Html.InputField(plan, m => m.AttendingPhysician, o => o.Label("Attending Physician"))
                    .AutoComplete(b => b
                        .Placeholder("Type to search physicians...")
                        .DebounceDelay(300)
                        .Reactive(plan, evt => evt.Filtering, (args, p) =>
                        {
                            args.PreventDefault(p);
                            p.Get("/Sandbox/Conditions/AdmissionAssessment/SearchPhysicians")
                             .Gather(g => g.FromEvent(args, x => x.Text, "q"))
                             .Response(r => r.OnSuccess<PhysicianSearchResponse>((json, s) =>
                             {
                                 args.UpdateData(s, json, j => j.Physicians);
                             }));
                        })); }
            </div>

            <!-- Row 3: Risk Tier (auto) + Is Veteran -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.RiskTier, o => o.Label("Risk Tier (auto)"))
                    .DropDownList(b => b
                        .DataSource(new[] { "", "Low", "Standard", "High" })
                        .Placeholder("Set by age")); }

                @{ Html.InputField(plan, m => m.IsVeteran, o => o.Label("Is Veteran"))
                    .Switch(b => b
                        .Reactive(plan, evt => evt.Changed, (args, p) =>
                        {
                            var sw = p.Component<FusionSwitch>(m => m.IsVeteran);
                            p.When(sw.Value()).Truthy()
                                .Then(t => t.Element("veteran-section").Show())
                                .Else(e => e.Element("veteran-section").Hide());
                        })); }
            </div>

            <!-- Status echoes -->
            <div class="font-mono text-sm space-y-1 mb-4">
                <p>Age echo: <span id="age-echo" class="text-text-muted">&mdash;</span></p>
                <p>Risk: <span id="risk-badge" hidden class="font-semibold text-accent">&mdash;</span></p>
                <p>Age status: <span id="age-status" class="text-text-muted">&mdash;</span></p>
            </div>

            <!-- Veteran section (conditionally visible) -->
            <div id="veteran-section" hidden>
                @await Html.PartialAsync("_VeteranDetails", Model)
            </div>

            <!-- Step 1 Navigation -->
            <div class="flex justify-end mt-6">
                @(Html.NativeButton("next-1", "Next: Clinical \u2192")
                    .CssClass("rounded-md bg-accent px-6 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Element("step-1").Hide();
                        p.Element("step-2").Show();
                        p.Element("step-ind-1").RemoveClass("font-bold");
                        p.Element("step-ind-1").RemoveClass("text-accent");
                        p.Element("step-ind-2").AddClass("font-bold");
                        p.Element("step-ind-2").AddClass("text-accent");
                    }))
            </div>
        </native-card-body></native-card>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Step 2: Clinical Assessment                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div id="step-2" hidden>
        <native-card><native-card-body>
            <native-heading level="H2">Step 2: Clinical Assessment</native-heading>
            <p class="text-sm text-text-secondary mb-4">
                Specialized clinical sections appear based on the primary diagnosis selected in Step 1.
            </p>

            <div id="cognitive-section" hidden>
                @await Html.PartialAsync("_CognitiveAssessment", Model)
            </div>

            <div id="cardiac-section" hidden>
                @await Html.PartialAsync("_CardiacAssessment", Model)
            </div>

            <div id="diabetes-section" hidden>
                @await Html.PartialAsync("_DiabetesManagement", Model)
            </div>

            <div id="no-assessment-text" hidden>
                <p class="text-sm text-text-secondary">No specialized clinical assessment required. Proceed to Step 3.</p>
            </div>

            <!-- Step 2 Navigation -->
            <div class="flex justify-between mt-6">
                @(Html.NativeButton("prev-2", "\u2190 Previous: Demographics")
                    .CssClass("rounded-md border border-border px-6 py-2 text-sm font-medium text-text-primary hover:bg-slate-50 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Element("step-2").Hide();
                        p.Element("step-1").Show();
                        p.Element("step-ind-2").RemoveClass("font-bold");
                        p.Element("step-ind-2").RemoveClass("text-accent");
                        p.Element("step-ind-1").AddClass("font-bold");
                        p.Element("step-ind-1").AddClass("text-accent");
                    }))
                @(Html.NativeButton("next-2", "Next: Functional \u2192")
                    .CssClass("rounded-md bg-accent px-6 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Element("step-2").Hide();
                        p.Element("step-3").Show();
                        p.Element("step-ind-2").RemoveClass("font-bold");
                        p.Element("step-ind-2").RemoveClass("text-accent");
                        p.Element("step-ind-3").AddClass("font-bold");
                        p.Element("step-ind-3").AddClass("text-accent");
                    }))
            </div>
        </native-card-body></native-card>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Step 3: Functional Assessment (wired in Task 10)                       -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div id="step-3" hidden>
        <native-card><native-card-body>
            <native-heading level="H2">Step 3: Functional Assessment</native-heading>
            <p class="text-sm text-text-secondary mb-4">
                Mobility, fall risk, and medication assessment. Conditions will be wired in Task 10.
            </p>

            <!-- Row 1: Fall History + Fall Risk Score -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.FallHistory, o => o.Label("Fall History"))
                    .DropDownList(b => b
                        .DataSource(fallOptions)
                        .Placeholder("Select fall history")); }

                @{ Html.InputField(plan, m => m.FallRiskScore, o => o.Label("Fall Risk Score"))
                    .NumericTextBox(b => b.Min(0).Max(10).Step(1)); }
            </div>

            <!-- Row 2: Mobility Aid + Medication Count -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.MobilityAid, o => o.Label("Mobility Aid"))
                    .DropDownList(b => b
                        .DataSource(mobilityAids)
                        .Placeholder("Select mobility aid")); }

                @{ Html.InputField(plan, m => m.MedicationCount, o => o.Label("Medication Count"))
                    .NumericTextBox(b => b.Min(0).Max(50).Step(1)); }
            </div>

            <!-- Row 3: Blood Thinners + Pain Medication -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.TakesBloodThinners, o => o.Label("Takes Blood Thinners"))
                    .Switch(b => { }); }

                @{ Html.InputField(plan, m => m.TakesPainMedication, o => o.Label("Takes Pain Medication"))
                    .Switch(b => { }); }
            </div>

            <!-- Conditional sections (hidden, wired in Task 10) -->
            <div id="fall-details" hidden>
                @await Html.PartialAsync("_FallDetails", Model)
            </div>

            <div id="pain-section" hidden>
                @await Html.PartialAsync("_PainAssessment", Model)
            </div>

            <div id="escort-indicator" hidden>
                <p class="text-sm font-semibold text-accent">Escort required for this resident.</p>
            </div>

            <div id="polypharmacy-warning" hidden>
                <p class="text-sm font-semibold text-orange-600">Polypharmacy alert: 5+ medications.</p>
            </div>

            <!-- Step 3 Navigation -->
            <div class="flex justify-between mt-6">
                @(Html.NativeButton("prev-3", "\u2190 Previous: Clinical")
                    .CssClass("rounded-md border border-border px-6 py-2 text-sm font-medium text-text-primary hover:bg-slate-50 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Element("step-3").Hide();
                        p.Element("step-2").Show();
                        p.Element("step-ind-3").RemoveClass("font-bold");
                        p.Element("step-ind-3").RemoveClass("text-accent");
                        p.Element("step-ind-2").AddClass("font-bold");
                        p.Element("step-ind-2").AddClass("text-accent");
                    }))
                @(Html.NativeButton("next-3", "Next: Review \u2192")
                    .CssClass("rounded-md bg-accent px-6 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Element("step-3").Hide();
                        p.Element("step-4").Show();
                        p.Element("step-ind-3").RemoveClass("font-bold");
                        p.Element("step-ind-3").RemoveClass("text-accent");
                        p.Element("step-ind-4").AddClass("font-bold");
                        p.Element("step-ind-4").AddClass("text-accent");
                    }))
            </div>
        </native-card-body></native-card>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Step 4: Review & Submit (wired in Task 10)                             -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div id="step-4" hidden>
        <native-card><native-card-body>
            <native-heading level="H2">Step 4: Review &amp; Submit</native-heading>
            <p class="text-sm text-text-secondary mb-4">
                Review summary and submit. Emergency contact is required. Submit wiring in Task 10.
            </p>

            <!-- Emergency Contact -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{ Html.InputField(plan, m => m.EmergencyContact, o => o.Required().Label("Emergency Contact"))
                    .NativeTextBox(b => b.Placeholder("Contact name and phone")); }
            </div>

            <div id="contact-warning" hidden>
                <p class="text-sm font-semibold text-red-600">Emergency contact is required before submission.</p>
            </div>

            <!-- Summary Panel -->
            <native-card><native-card-body>
                <native-heading level="H3">Assessment Summary</native-heading>
                <div class="font-mono text-sm space-y-1">
                    <p>Risk Tier: <span id="summary-risk-tier" class="text-text-muted">&mdash;</span></p>
                    <p>Care Unit: <span id="summary-care-unit" class="text-text-muted">&mdash;</span></p>
                    <p>Monitoring Level: <span id="summary-monitoring-level" class="text-text-muted">&mdash;</span></p>
                </div>
            </native-card-body></native-card>

            <!-- Validation Summary -->
            <div id="validation-summary" hidden>
                <p class="text-sm font-semibold text-red-600">Please fix the errors above before submitting.</p>
            </div>

            <!-- Step 4 Navigation -->
            <div class="flex justify-between mt-6">
                @(Html.NativeButton("prev-4", "\u2190 Previous: Functional")
                    .CssClass("rounded-md border border-border px-6 py-2 text-sm font-medium text-text-primary hover:bg-slate-50 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Element("step-4").Hide();
                        p.Element("step-3").Show();
                        p.Element("step-ind-4").RemoveClass("font-bold");
                        p.Element("step-ind-4").RemoveClass("text-accent");
                        p.Element("step-ind-3").AddClass("font-bold");
                        p.Element("step-ind-3").AddClass("text-accent");
                    }))
                @(Html.NativeButton("submit-btn", "Submit Assessment")
                    .CssClass("rounded-md bg-accent px-6 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors"))
            </div>
        </native-card-body></native-card>
    </div>

    <!-- Plan JSON (debug) -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
