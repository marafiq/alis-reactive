@model NumericConditionModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "Numeric Conditions";

    var plan = Html.ReactivePlan<NumericConditionModel>();

    // ── Section 1: Simple condition — When(comp.Value()).Gt(100m) ──
    // HeartRate change → Gt(100) shows tachycardia warning, Else hides it

    // ── Section 2: ElseIf grade ladder — comp.Value() ranges ──
    // HeartRate change → Gte(120) "Critical" / Gte(100) "High" / Gte(60) "Normal" / Else "Low"

    // ── Section 3: AND compound — Gt(60) AND Lt(100) → "Normal range" ──
    // BloodPressure change → compound condition

    // ── Section 4: Cross-component — When(heartRate).Gte(threshold) ──
    // Button click reads both components and compares
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">Numeric Conditions — Vital Signs</native-heading>
        <native-text color="Secondary">
            Conditions with FusionNumericTextBox: simple Gt, ElseIf ladder, AND compound,
            and cross-component source-vs-source comparison. Senior living domain: vital sign thresholds.
        </native-text>
    </div>

    <!-- Section 1: Simple Gt condition -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Simple Condition — Gt(100)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Enter a heart rate. Values above 100 show a tachycardia warning.
            Uses <code>When(comp.Value()).Gt(100m)</code> as a component-read condition.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.HeartRate, o => o.Label("Heart Rate (bpm)"))
                .FusionNumericTextBox(b => b
                    .Min(0).Max(300).Step(1)
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        var comp = p.Component<FusionNumericTextBox>(m => m.HeartRate);

                        // Simple condition: Gt(100) → tachycardia warning
                        p.When(comp.Value()).Gt(100m)
                            .Then(then =>
                            {
                                then.Element("tachycardia-warning").Show();
                                then.Element("tachycardia-warning").SetText("Tachycardia detected");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("tachycardia-warning").Hide();
                            });

                        // ElseIf ladder: heart rate zones
                        p.When(comp.Value()).Gte(120m)
                            .Then(t => t.Element("hr-zone").SetText("Critical"))
                            .ElseIf(comp.Value()).Gte(100m)
                            .Then(t => t.Element("hr-zone").SetText("High"))
                            .ElseIf(comp.Value()).Gte(60m)
                            .Then(t => t.Element("hr-zone").SetText("Normal"))
                            .Else(e => e.Element("hr-zone").SetText("Low"));
                    })); }
        </div>
        <div class="font-mono text-sm">
            <p>Warning: <span id="tachycardia-warning" hidden class="text-rose-600">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 2: ElseIf grade ladder -->
    <native-card><native-card-body>
        <native-heading level="H2">2. ElseIf Ladder — Heart Rate Zones</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Same heart rate field drives a multi-branch condition:
            <code>Gte(120) → "Critical" / Gte(100) → "High" / Gte(60) → "Normal" / Else → "Low"</code>.
            Uses component-read source with ElseIf chaining.
        </p>
        <div class="font-mono text-sm">
            <p>Zone: <span id="hr-zone" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 3: AND compound condition -->
    <native-card><native-card-body>
        <native-heading level="H2">3. AND Compound — Normal Range</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Blood pressure field uses a compound condition:
            <code>When(comp.Value()).Gte(60m).And(comp.Value()).Lte(120m)</code> shows "Normal range".
            Outside that range shows "Out of range".
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.BloodPressure, o => o.Label("Systolic BP (mmHg)"))
                .FusionNumericTextBox(b => b
                    .Min(0).Max(300).Step(1)
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        var comp = p.Component<FusionNumericTextBox>(m => m.BloodPressure);
                        p.When(comp.Value()).Gte(60m)
                            .And(comp.Value()).Lte(120m)
                            .Then(then =>
                            {
                                then.Element("bp-range").SetText("Normal range");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("bp-range").SetText("Out of range");
                            });
                    })); }
        </div>
        <div class="font-mono text-sm">
            <p>Range: <span id="bp-range" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 4: Cross-component source-vs-source -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Cross-Component — Value vs Threshold</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Compares heart rate against a configurable threshold using source-vs-source:
            <code>When(heartRate.Value()).Gte(threshold.Value())</code>.
            Button-triggered so both components are read at click time.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.ThresholdValue, o => o.Label("Threshold (bpm)"))
                .FusionNumericTextBox(b => b
                    .Min(0).Max(300).Step(1)); }
        </div>
        <div class="mt-3">
            @(Html.NativeButton("check-threshold-btn", "Check Against Threshold")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    var hr = p.Component<FusionNumericTextBox>(m => m.HeartRate);
                    var threshold = p.Component<FusionNumericTextBox>(m => m.ThresholdValue);
                    p.When(hr.Value()).Gte(threshold.Value())
                        .Then(t => t.Element("threshold-result").SetText("Above threshold"))
                        .Else(e => e.Element("threshold-result").SetText("Below threshold"));
                }))
        </div>
        <div class="font-mono text-sm mt-2">
            <p>Result: <span id="threshold-result" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
