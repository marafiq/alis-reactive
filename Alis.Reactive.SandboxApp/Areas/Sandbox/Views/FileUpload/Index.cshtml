@model FileUploadModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@using Alis.Reactive.Fusion.Extensions
@using Syncfusion.EJ2.Inputs
@{
    ViewData["Title"] = "FusionFileUpload";

    var plan = Html.ReactivePlan<FileUploadModel>();
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">FusionFileUpload — Full API</native-heading>
        <native-text color="Secondary">
            Exercises FusionFileUpload vertical slice: Syncfusion Uploader in form mode
            (no auto-upload). Files travel via FormData POST — they cannot travel via JSON.
            Senior living domain: resident document uploads (medical records, photos, consent forms).
        </native-text>
    </div>

    <!-- Section 1: Form with TextBox + FileUpload -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Document Upload Form</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            A text field for the resident name and a Syncfusion Uploader for documents.
            Accepts .pdf, .jpg, .png, .txt files. Multiple file selection is enabled.
        </p>
        <form id="upload-form">
            @{ Html.InputField(plan, m => m.ResidentName, o => o.Label("Resident Name"))
                .NativeTextBox(b => b
                    .Placeholder("Enter resident name")
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")); }
            @{ Html.InputField(plan, m => m.Documents, o => o.Label("Documents"))
                .FileUpload(b => b.AllowedExtensions(".pdf,.jpg,.png,.txt").Multiple(true)); }
        </form>
    </native-card-body></native-card>

    <!-- Section 2: FormData POST with Echo -->
    <native-card><native-card-body>
        <native-heading level="H2">2. FormData POST (Echo)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Clicks "Upload" to POST the form as multipart/form-data. Server echoes back
            the resident name, file count, file names, and file sizes — proving files
            survive the gather + FormData transport.
        </p>
        @(Html.NativeButton("upload-btn", "Upload")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/FileUpload/Echo", g => g.IncludeAll())
                 .AsFormData()
                 .Response(r => r
                    .OnSuccess<FileUploadEchoResponse>((json, s) =>
                    {
                        s.Element("echo-name").SetText(json, x => x.ResidentName);
                        s.Element("echo-count").SetText(json, x => x.FileCount);
                        s.Element("echo-files").SetText(json, x => x.FileNames);
                        s.Element("echo-sizes").SetText(json, x => x.FileSizes);
                        s.Element("echo-result").AddClass("text-green-600");
                    })
                 );
            }))
        <div id="echo-result" class="mt-4 space-y-1 font-mono text-sm text-text-muted">
            <p>Resident Name: <span id="echo-name">&mdash;</span></p>
            <p>File Count: <span id="echo-count">&mdash;</span></p>
            <p>File Names: <span id="echo-files">&mdash;</span></p>
            <p>File Sizes: <span id="echo-sizes">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
