@model NativeCheckListModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.SandboxApp.Areas.Sandbox.Models
@{
    ViewData["Title"] = "NativeCheckList";

    var plan = Html.ReactivePlan<NativeCheckListModel>();
    var allergyItems = (RadioButtonItem[])ViewBag.AllergyItems;
    var amenityItems = (RadioButtonItem[])ViewBag.AmenityItems;
    var dietaryItems = (RadioButtonItem[])ViewBag.DietaryItems;
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">NativeCheckList</native-heading>
        <native-text color="Secondary">
            Checkbox list: text + description variation, text-only variation,
            form submission (JSON POST), component value condition, and model binding proof.
        </native-text>
    </div>

    <!-- Section 1: Text + Description -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Text + Description Checkbox List</native-heading>
        <native-text color="Secondary">
            Rich checkbox options with label and description. Pre-selected from model: <code>Peanuts,Dairy</code>.
        </native-text>

        @{ Html.InputField(plan, m => m.Allergies, o => o.Label("Allergies"))
            .NativeCheckList(b => b
                .Items(allergyItems)
                .Reactive(plan, evt => evt.Changed, (args, p) =>
                {
                    p.Element("allergy-echo").SetText(args, a => a.Value);
                })); }

        <div class="font-mono text-sm">
            <p>Selected: <span id="allergy-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 2: Text-Only -->
    <native-card><native-card-body>
        <native-heading level="H2">2. Text-Only Checkbox List</native-heading>
        <native-text color="Secondary">
            Simple checkbox options with label text only. Uses <code>.Items(amenityItems)</code>.
        </native-text>

        @{ Html.InputField(plan, m => m.Amenities, o => o.Label("Amenities"))
            .NativeCheckList(b => b.Items(amenityItems)); }
    </native-card-body></native-card>

    <!-- Section 3: Form with Validation -->
    <native-card><native-card-body>
        <native-heading level="H2">3. Form — JSON POST + FluentValidation</native-heading>
        <native-text color="Secondary">
            All fields gathered via <code>IncludeAll()</code>, validated client-side by
            <code>NativeCheckListFormValidator</code>, then POST as JSON. Server validates and returns errors.
        </native-text>

        <form id="checklist-form" class="space-y-4">
            @{ Html.InputField(plan, m => m.ResidentName, o => o.Required().Label("Resident Name"))
                .NativeTextBox(b => b.Placeholder("Full resident name")); }

            @{ Html.InputField(plan, m => m.DietaryNeeds, o => o.Required().Label("Dietary Needs"))
                .NativeCheckList(b => b.Items(dietaryItems)); }

            <div class="flex items-center gap-4">
                @(Html.NativeButton("submit-btn", "Submit Preferences")
                    .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                    .Reactive(plan, evt => evt.Click, (args, p) =>
                    {
                        p.Post("/Sandbox/NativeCheckList/Submit", g => g.IncludeAll())
                         .Validate<NativeCheckListFormValidator>("checklist-form")
                         .Response(r => r
                            .OnSuccess(s => s.Element("result").SetText("Preferences saved"))
                            .OnError(400, e =>
                            {
                                e.ValidationErrors("checklist-form");
                            }));
                    }))

                <p id="result" class="text-sm text-text-muted"></p>
            </div>
        </form>
    </native-card-body></native-card>

    <!-- Section 4: Component Value Condition -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Component Value Condition</native-heading>
        <native-text color="Secondary">
            Button reads allergies via <code>When(comp.Value()).NotEmpty()</code>.
        </native-text>

        @(Html.NativeButton("check-allergy-btn", "Check Allergies")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                var comp = p.Component<NativeCheckList>(m => m.Allergies);
                p.When(comp.Value()).NotEmpty()
                    .Then(t => t.Element("allergy-confirmation").SetText("allergies recorded"))
                    .Else(e => e.Element("allergy-confirmation").SetText("no allergies selected"));
            }))
        <div class="font-mono text-sm">
            <p>Status: <span id="allergy-confirmation" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 5: Model Binding Proof -->
    <native-card><native-card-body>
        <native-heading level="H2">5. Model Binding Proof</native-heading>
        <native-text color="Secondary">
            Controller sets <code>Allergies = ["Peanuts","Dairy"]</code> — checkboxes pre-select on load.
            Hidden input value: <code>@(Model.Allergies != null ? string.Join(",", Model.Allergies) : "(empty)")</code>.
        </native-text>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
