@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.CheckBoxModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@{
    ViewData["Title"] = "NativeCheckBox";

    var plan = Html.ReactivePlan<CheckBoxModel>();

    // Section 1: Property write — DomReady sets ReceivesMedication to false (unchecks it)
    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<NativeCheckBox>(m => m.ReceivesMedication).SetChecked(false);
    }));

    // Section 2: Property read — DomReady reads AllowsVisitors value into echo
    Html.On(plan, t => t.DomReady(p =>
    {
        var comp = p.Component<NativeCheckBox>(m => m.AllowsVisitors);
        p.Element("value-echo").SetText(comp.Value());
    }));
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold tracking-tight">NativeCheckBox — Full API</h1>
        <p class="mt-2 text-text-secondary">
            Exercises NativeCheckBox vertical slice: property writes (SetChecked),
            property reads (Value), events (Changed with typed condition), and component-read conditions.
            Senior living domain: resident medication, visitors, and dietary restrictions.
        </p>
    </div>

    <!-- Section 1: Property Write -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">1. Property Write (SetChecked)</h2>
        <p class="text-sm text-text-secondary mb-4">
            Checkbox starts checked. On DomReady, <code>SetChecked(false)</code> unchecks it.
        </p>
        @{ Html.InputField(plan, m => m.ReceivesMedication, o => o.Label("Receives Medication"))
            .NativeCheckBox(b => b.CssClass("h-4 w-4 rounded border-border text-accent")); }
    </section>

    <!-- Section 2: Property Read -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">2. Property Read (Value as Source)</h2>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the AllowsVisitors checkbox value and echoes it.
        </p>
        @{ Html.InputField(plan, m => m.AllowsVisitors, o => o.Label("Allows Visitors"))
            .NativeCheckBox(b => b.CssClass("h-4 w-4 rounded border-border text-accent")); }
        <div class="font-mono text-sm mt-2">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </section>

    <!-- Section 3: Event + Event-Args Condition -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">3. Changed Event with Typed Condition</h2>
        <p class="text-sm text-text-secondary mb-4">
            Dietary restrictions checkbox wires a Changed event with typed condition:
            <code>When(args, x =&gt; x.Checked).Truthy()</code> shows/hides the restrictions panel.
        </p>
        @{ Html.InputField(plan, m => m.HasDietaryRestrictions, o => o.Label("Has Dietary Restrictions"))
            .NativeCheckBox(b => b
                .CssClass("h-4 w-4 rounded border-border text-accent")
                .Reactive(plan, evt => evt.Changed, (args, p) =>
                {
                    p.When(args, a => a.Checked).Truthy()
                        .Then(t =>
                        {
                            t.Element("restrictions-panel").Show();
                            t.Element("restrictions-status").SetText("checked");
                            t.Element("restrictions-status").AddClass("text-green-600");
                            t.Element("restrictions-status").RemoveClass("text-text-muted");
                        })
                        .Else(e =>
                        {
                            e.Element("restrictions-panel").Hide();
                            e.Element("restrictions-status").SetText("unchecked");
                            e.Element("restrictions-status").RemoveClass("text-green-600");
                        });
                })); }
        <div class="font-mono text-sm mt-2">
            <p>Status: <span id="restrictions-status" class="text-text-muted">&mdash;</span></p>
        </div>
        <div id="restrictions-panel" hidden class="rounded-md bg-slate-100 p-4 text-sm mt-2">
            Resident has dietary restrictions on file. Review care plan.
        </div>
    </section>

    <!-- Section 4: Component-Read Condition -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">4. Component Value Condition</h2>
        <p class="text-sm text-text-secondary mb-4">
            Button reads medication checkbox via <code>When(comp.Value()).Truthy()</code>
            and shows a confirmation or warning.
        </p>
        @(Html.NativeButton("check-medication-btn", "Check Medication Status")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                var comp = p.Component<NativeCheckBox>(m => m.ReceivesMedication);
                p.When(comp.Value()).Truthy()
                    .Then(t => t.Element("medication-warning").SetText("resident receives medication"))
                    .Else(e => e.Element("medication-warning").SetText("no medication on record"));
            }))
        <div class="font-mono text-sm mt-2">
            <p>Status: <span id="medication-warning" class="text-text-muted">&mdash;</span></p>
        </div>
    </section>

    <!-- Plan JSON -->
    <section class="rounded-lg border border-border bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4">Plan JSON</h2>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </section>
</div>

@Html.RenderPlan(plan)
