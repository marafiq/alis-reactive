@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.InputMaskModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "FusionInputMask";

    var plan = Html.ReactivePlan<InputMaskModel>();

    // ── Section 1: Property Write (SetValue) from DomReady ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<FusionInputMask>(m => m.PhoneNumber).SetValue("(555) 123-4567");
    }));

    // ── Section 2: Property Read — display current value in echo text ──

    Html.On(plan, t => t.DomReady(p =>
    {
        var comp = p.Component<FusionInputMask>(m => m.PhoneNumber);
        p.Element("value-echo").SetText(comp.Value());
    }));
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">FusionInputMask — Full API</native-heading>
        <native-text color="Secondary">
            Exercises all supported FusionInputMask API: property writes, property reads,
            events with typed conditions, and component-read conditions.
            Senior living domain: phone numbers, SSN, insurance IDs.
        </native-text>
    </div>

    <!-- Section 1: Property Write (SetValue) -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Property Write (SetValue)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, sets phone number to (555) 123-4567 via structured prop on the Syncfusion ej2 instance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.InputField(plan, m => m.PhoneNumber, o => o.Label("Phone Number"))
                .InputMask(b => b
                    .Mask("(000) 000-0000")
                    .Placeholder("Enter phone number")
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("change-value").SetText(args, x => x.Value);
                        p.When(args, x => x.Value).NotEmpty()
                            .Then(t => t.Element("args-condition").SetText("phone entered"))
                            .Else(e => e.Element("args-condition").SetText("no phone"));
                        var comp = p.Component<FusionInputMask>(m => m.PhoneNumber);
                        p.When(comp.Value()).NotEmpty()
                            .Then(then =>
                            {
                                then.Element("selected-indicator").Show();
                                then.Element("selected-indicator").SetText("phone on file");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("selected-indicator").Hide();
                            });
                    })); }
        </div>
    </native-card-body></native-card>

    <!-- Section 2: Property Read — Echo Value -->
    <native-card><native-card-body>
        <native-heading level="H2">2. Property Read (Value as Source)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the phone number component's <code>value</code> property and displays it in a text element.
        </p>
        <div class="font-mono text-sm">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 3: Events — Changed with typed condition -->
    <native-card><native-card-body>
        <native-heading level="H2">3. Events (Changed + Typed Condition)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            The phone number field wires a Changed event. Change shows the new value.
            <code>When(args, x =&gt; x.Value).NotEmpty()</code> tests typed event-args condition.
        </p>
        <div class="font-mono text-sm space-y-1">
            <p>Change value: <span id="change-value" class="text-text-muted">&mdash;</span></p>
            <p>Args condition: <span id="args-condition" class="text-text-muted">&mdash;</span></p>
            <p>On file: <span id="selected-indicator" hidden class="text-emerald-600">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 4: Component-Read Condition -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Component Value Condition</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Button reads phone number via <code>When(comp.Value()).IsEmpty()</code>
            and shows a warning or confirmation.
        </p>
        <div class="mt-3">
            @(Html.NativeButton("check-phone-btn", "Check Phone Number")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    var comp = p.Component<FusionInputMask>(m => m.PhoneNumber);
                    p.When(comp.Value()).IsEmpty()
                        .Then(t => t.Element("phone-warning").SetText("phone number is required"))
                        .Else(e => e.Element("phone-warning").SetText("phone number set"));
                }))
        </div>
        <div class="font-mono text-sm mt-2">
            <p>Warning: <span id="phone-warning" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
