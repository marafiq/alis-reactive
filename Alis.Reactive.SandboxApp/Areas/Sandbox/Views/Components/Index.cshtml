@{
    ViewData["Title"] = "Components";
}

<div class="mb-6">
    <a href="/Sandbox" class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-[#7A2E3B] transition-colors">
        <span>&larr;</span> Back to Sandbox
    </a>
</div>

<h1 class="text-2xl font-bold text-text-primary mb-2">Components</h1>
<p class="text-text-secondary mb-8">Input vertical slices across all vendors</p>

