@model NumericTextBoxModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "NumericTextBox";

    var plan = Html.ReactivePlan<NumericTextBoxModel>();

    // ── Section 1+2: Property Write (SetValue + SetMin) + Property Read on DomReady ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<FusionNumericTextBox>(m => m.Amount).SetValue(42);
        p.Component<FusionNumericTextBox>(m => m.Amount).SetMin(0);
        var comp = p.Component<FusionNumericTextBox>(m => m.Amount);
        p.Element("value-echo").SetText(comp.Value());
    }));

    // ── Section 4: Conditions — both event-args and component-read ──
    // Wired via the Changed event on the Temperature NumericTextBox:
    //   When(args, x => x.Value).Gt(100m)  — event-args condition
    //   When(comp.Value()).Gt(0m)           — component-read condition

    // ── Section 5: Gather — POST with Include ──

    Html.On(plan, t => t.CustomEvent("do-gather", p =>
    {
        p.Post("/Sandbox/Components/NumericTextBox/Echo", g =>
            g.Include<FusionNumericTextBox, NumericTextBoxModel>(m => m.Amount))
         .Response(r => r
            .OnSuccess(s =>
            {
                s.Element("gather-result").SetText("gathered");
            }));
    }));
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">FusionNumericTextBox — Full API</native-heading>
        <native-text color="Secondary">
            Exercises all supported FusionNumericTextBox API: property writes, method calls,
            property reads, events, conditions, and gather.
        </native-text>
    </div>

    <!-- Section 1: Property Write (SetValue + SetMin) -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Property Write (SetValue + SetMin)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, sets value=42 and min=0 via structured prop on the Syncfusion ej2 instance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.InputField(plan, m => m.Amount, o => o.Label("Amount (SF NumericTextBox)"))
                .NumericTextBox(b => b
                    .Min(-100).Max(99999).Step(1)); }
        </div>
    </native-card-body></native-card>

    <!-- Section 2: Property Read — Echo Value -->
    <native-card><native-card-body>
        <native-heading level="H2">2. Property Read (Value as Source)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the Amount component's <code>value</code> property and displays it in a text element.
        </p>
        <div class="font-mono text-sm">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 3: Method Calls (Increment / Decrement) -->
    <native-card><native-card-body>
        <native-heading level="H2">3. Method Calls (Increment / Decrement)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Buttons invoke <code>el.increment()</code> and <code>el.decrement()</code> on the Syncfusion instance.
            After each call, the <code>change</code> event fires and updates the echo.
        </p>
        <div class="flex gap-2 mb-3">
            @(Html.NativeButton("increment-btn", "Increment")
                .CssClass("rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionNumericTextBox>(m => m.Amount).Increment();
                }))
            @(Html.NativeButton("decrement-btn", "Decrement")
                .CssClass("rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionNumericTextBox>(m => m.Amount).Decrement();
                }))
        </div>
        <div class="font-mono text-sm">
            <p>Method result: <span id="method-result" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 4: Events — Changed, Focus, Blur -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Events (Changed, Focus, Blur)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            The Temperature field wires all three events. Change shows the new value,
            Focus/Blur show focus state.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.Temperature, o => o.Label("Temperature (SF NumericTextBox)"))
                .NumericTextBox(b => b
                    .Min(-50).Max(150).Step(1)
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("change-value").SetText(args, x => x.Value);
                        // Event-args condition: When(args, x => x.Value).Gt(100m)
                        p.When(args, x => x.Value).Gt(100m)
                            .Then(then =>
                            {
                                then.Element("high-temp-warning").Show();
                                then.Element("high-temp-warning").SetText("high");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("high-temp-warning").Hide();
                            });
                        // Component-read condition: When(comp.Value()).Gt(0m)
                        var comp = p.Component<FusionNumericTextBox>(m => m.Temperature);
                        p.When(comp.Value()).Gt(0m)
                            .Then(then =>
                            {
                                then.Element("positive-indicator").Show();
                                then.Element("positive-indicator").SetText("positive");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("positive-indicator").Hide();
                            });
                    })
                    .Reactive(plan, evt => evt.Focus, (args, p) =>
                    {
                        p.Element("focus-state").SetText("focused");
                    })
                    .Reactive(plan, evt => evt.Blur, (args, p) =>
                    {
                        p.Element("focus-state").SetText("blurred");
                    })); }
        </div>
        <div class="font-mono text-sm space-y-1">
            <p>Change value: <span id="change-value" class="text-text-muted">&mdash;</span></p>
            <p>Focus state: <span id="focus-state" class="text-text-muted">&mdash;</span></p>
            <p>Positive: <span id="positive-indicator" hidden class="text-emerald-600">&mdash;</span></p>
            <p>High temp: <span id="high-temp-warning" hidden class="text-rose-600">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 5: Condition — Positive Indicator -->
    <native-card><native-card-body>
        <native-heading level="H2">5. Conditions (Both Patterns)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Section 4 exercises both typed condition patterns:
            <code>When(args, x =&gt; x.Value).Gt(100m)</code> (event-args) shows a high-temp warning,
            <code>When(comp.Value()).Gt(0m)</code> (component-read) shows a positive indicator.
            Enter a value &gt; 100 to see both; enter 1–100 to see only the positive indicator.
        </p>
    </native-card-body></native-card>

    <!-- Section 6: Gather — Include in POST -->
    <native-card><native-card-body>
        <native-heading level="H2">6. Gather (Include in POST)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Click to POST the Amount value gathered from the Syncfusion component via
            <code>Include&lt;FusionNumericTextBox&gt;</code>.
        </p>
        @(Html.NativeButton("gather-btn", "Gather Amount")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors mb-3")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Dispatch("do-gather");
            }))
        <div class="font-mono text-sm">
            <p>Gather result: <span id="gather-result" class="text-text-muted">not gathered</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 7: Increment/Decrement Tracking -->
    <native-card><native-card-body>
        <native-heading level="H2">7. Quantity with Increment/Decrement Tracking</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            A standalone quantity field with its own change event.
            Increment and decrement buttons update the value and the echo tracks changes.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.Quantity, o => o.Label("Quantity (SF NumericTextBox)"))
                .NumericTextBox(b => b
                    .Min(0).Max(100).Step(1).Value(1)
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("method-result").SetText(args, x => x.Value);
                        p.Element("qty-echo").SetText(args, x => x.Value);
                    })); }
        </div>
        <div class="flex gap-2 mb-3">
            @(Html.NativeButton("qty-inc-btn", "Qty +1")
                .CssClass("rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionNumericTextBox>(m => m.Quantity).Increment();
                }))
            @(Html.NativeButton("qty-dec-btn", "Qty -1")
                .CssClass("rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionNumericTextBox>(m => m.Quantity).Decrement();
                }))
        </div>
        <div class="font-mono text-sm">
            <p>Quantity echo: <span id="qty-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
