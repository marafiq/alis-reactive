@model ColorPickerModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "FusionColorPicker";

    var plan = Html.ReactivePlan<ColorPickerModel>();

    // -- Section 1+2: Property Write (SetValue) + Property Read on DomReady --

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<FusionColorPicker>(m => m.ThemeColor).SetValue("#e11d48");
        var comp = p.Component<FusionColorPicker>(m => m.ThemeColor);
        p.Element("value-echo").SetText(comp.Value());
        p.Element("set-value-result").SetText("SetValue applied");
    }));
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">FusionColorPicker — Full API</native-heading>
        <native-text color="Secondary">
            Exercises all supported FusionColorPicker API: property writes, property reads,
            method calls, events with typed conditions, and component-read conditions.
            Senior living domain: facility branding theme and accent colors.
        </native-text>
    </div>

    <!-- Section 1: Property Write (SetValue) -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Property Write (SetValue)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, sets theme color to <code>#e11d48</code> (rose-600) via structured prop
            on the Syncfusion ej2 instance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.InputField(plan, m => m.ThemeColor, o => o.Label("Theme Color"))
                .ColorPicker(b => b
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("change-value").SetText(args, x => x.Value);
                        p.When(args, x => x.Value).Eq("#e11d48ff")
                            .Then(t => t.Element("args-condition").SetText("rose selected"))
                            .Else(e => e.Element("args-condition").SetText("other color"));
                        var comp = p.Component<FusionColorPicker>(m => m.ThemeColor);
                        p.When(comp.Value()).NotEmpty()
                            .Then(then =>
                            {
                                then.Element("selected-indicator").Show();
                                then.Element("selected-indicator").SetText("color active");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("selected-indicator").Hide();
                            });
                    })); }
        </div>
        <div class="font-mono text-sm mt-4">
            <p>SetValue result: <span id="set-value-result" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 2: Property Read — Echo Value -->
    <native-card><native-card-body>
        <native-heading level="H2">2. Property Read (Value as Source)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the theme color component's <code>value</code> property and displays it in a text element.
        </p>
        <div class="font-mono text-sm">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 3: Method Call (Toggle) -->
    <native-card><native-card-body>
        <native-heading level="H2">3. Method Call (Toggle)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Button calls <code>toggle()</code> on the accent color picker to open/close its popup.
        </p>
        @{ Html.InputField(plan, m => m.AccentColor, o => o.Label("Accent Color"))
            .ColorPicker(b => { }); }
        <div class="mt-3">
            @(Html.NativeButton("toggle-btn", "Toggle Accent Picker")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Component<FusionColorPicker>(m => m.AccentColor).Toggle();
                    p.Element("method-result").SetText("toggle called");
                }))
        </div>
        <div class="font-mono text-sm mt-2">
            <p>Method result: <span id="method-result" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 4: Events — Changed with typed condition -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Events (Changed + Typed Condition)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            The theme color field wires a Changed event. Change shows current and previous values.
            <code>When(args, x =&gt; x.CurrentValue).Eq("#e11d48")</code> tests typed event-args condition.
        </p>
        <div class="font-mono text-sm space-y-1">
            <p>Color value: <span id="change-value" class="text-text-muted">&mdash;</span></p>
            <p>Args condition: <span id="args-condition" class="text-text-muted">&mdash;</span></p>
            <p>Active: <span id="selected-indicator" hidden class="text-emerald-600">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 5: Component-Read Condition -->
    <native-card><native-card-body>
        <native-heading level="H2">5. Component Value Condition (Accent Color)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Button reads accent color via <code>When(comp.Value()).IsEmpty()</code>
            and shows a warning or confirmation.
        </p>
        <div class="mt-3">
            @(Html.NativeButton("check-accent-btn", "Check Accent Color")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    var comp = p.Component<FusionColorPicker>(m => m.AccentColor);
                    p.When(comp.Value()).IsEmpty()
                        .Then(t => t.Element("component-read-result").SetText("no accent color set"))
                        .Else(e => e.Element("component-read-result").SetText("accent color is set"));
                }))
        </div>
        <div class="font-mono text-sm mt-2">
            <p>Status: <span id="component-read-result" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
