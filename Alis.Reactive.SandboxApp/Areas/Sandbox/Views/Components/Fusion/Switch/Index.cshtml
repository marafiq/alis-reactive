@model SwitchModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    ViewData["Title"] = "FusionSwitch";

    var plan = Html.ReactivePlan<SwitchModel>();

    // ── Section 1+2: Property Write (SetChecked) + Property Read on DomReady ──

    Html.On(plan, t => t.DomReady(p =>
    {
        p.Component<FusionSwitch>(m => m.ReceiveNotifications).SetChecked(false);
        var comp = p.Component<FusionSwitch>(m => m.EmailAlerts);
        p.Element("value-echo").SetText(comp.Value());
    }));
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">FusionSwitch — Full API</native-heading>
        <native-text color="Secondary">
            Exercises all supported FusionSwitch API: property writes, property reads,
            events with typed conditions, and component-read conditions.
            Senior living domain: notification preferences, email/SMS alerts.
        </native-text>
    </div>

    <!-- Section 1: Property Write (SetChecked) -->
    <native-card><native-card-body>
        <native-heading level="H2">1. Property Write (SetChecked)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Switch starts checked. On DomReady, <code>SetChecked(false)</code> unchecks it
            via structured prop on the Syncfusion ej2 instance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.InputField(plan, m => m.ReceiveNotifications, o => o.Label("Receive Notifications"))
                .FusionSwitch(b => b
                    .Reactive(plan, evt => evt.Changed, (args, p) =>
                    {
                        p.Element("change-value").SetText(args, x => x.Checked);
                        p.When(args, x => x.Checked).Truthy()
                            .Then(t => t.Element("args-condition").SetText("notifications enabled"))
                            .Else(e => e.Element("args-condition").SetText("notifications disabled"));
                        var comp = p.Component<FusionSwitch>(m => m.ReceiveNotifications);
                        p.When(comp.Value()).Truthy()
                            .Then(then =>
                            {
                                then.Element("selected-indicator").Show();
                                then.Element("selected-indicator").SetText("notifications active");
                            })
                            .Else(else_ =>
                            {
                                else_.Element("selected-indicator").Hide();
                            });
                    })); }
        </div>
    </native-card-body></native-card>

    <!-- Section 2: Property Read — Echo Value -->
    <native-card><native-card-body>
        <native-heading level="H2">2. Property Read (Value as Source)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            On DomReady, reads the email alerts switch's <code>checked</code> property and displays it in a text element.
        </p>
        @{ Html.InputField(plan, m => m.EmailAlerts, o => o.Label("Email Alerts"))
            .FusionSwitch(b => { }); }
        <div class="font-mono text-sm mt-2">
            <p>Value echo: <span id="value-echo" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 3: Events — Changed with typed condition -->
    <native-card><native-card-body>
        <native-heading level="H2">3. Events (Changed + Typed Condition)</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            The notifications switch wires a Changed event. Toggle shows the new state.
            <code>When(args, x =&gt; x.Checked).Truthy()</code> tests typed event-args condition.
        </p>
        <div class="font-mono text-sm space-y-1">
            <p>Change value: <span id="change-value" class="text-text-muted">&mdash;</span></p>
            <p>Args condition: <span id="args-condition" class="text-text-muted">&mdash;</span></p>
            <p>Active: <span id="selected-indicator" hidden class="text-emerald-600">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Section 4: Component-Read Condition -->
    <native-card><native-card-body>
        <native-heading level="H2">4. Component Value Condition</native-heading>
        <p class="text-sm text-text-secondary mb-4">
            Button reads SMS alerts switch via <code>When(comp.Value()).Truthy()</code>
            and shows a confirmation or warning.
        </p>
        @{ Html.InputField(plan, m => m.SmsAlerts, o => o.Label("SMS Alerts"))
            .FusionSwitch(b => { }); }
        <div class="mt-3">
            @(Html.NativeButton("check-sms-btn", "Check SMS Alert Status")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    var comp = p.Component<FusionSwitch>(m => m.SmsAlerts);
                    p.When(comp.Value()).Truthy()
                        .Then(t => t.Element("sms-warning").SetText("SMS alerts are enabled"))
                        .Else(e => e.Element("sms-warning").SetText("SMS alerts are disabled"));
                }))
        </div>
        <div class="font-mono text-sm mt-2">
            <p>Status: <span id="sms-warning" class="text-text-muted">&mdash;</span></p>
        </div>
    </native-card-body></native-card>

    <!-- Plan JSON -->
    <native-card><native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto max-h-96"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body></native-card>
</native-vstack>

@Html.RenderPlan(plan)
