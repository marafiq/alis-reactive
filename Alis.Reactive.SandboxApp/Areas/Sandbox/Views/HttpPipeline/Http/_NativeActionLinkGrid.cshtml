@model IReadOnlyList<HttpActionLinkRow>
@using Alis.Reactive.Native.Components

<native-vstack gap="Base">
    @foreach (var row in Model)
    {
        <div data-testid="native-action-link-row-@row.Id" class="flex items-center justify-between rounded-md border border-border px-3 py-2">
            <div class="text-sm text-slate-700">
                <span class="font-medium">Resident #@row.Id</span>
                <span class="text-text-secondary"> - @row.Name</span>
            </div>
            @(Html.NativeActionLink("Delete", $"/Sandbox/HttpPipeline/Http/ActionLinkDelete/{row.Id}", p => p
                .Confirm($"Delete resident #{row.Id}?")
                .Then(t => t
                    .Post($"/Sandbox/HttpPipeline/Http/ActionLinkDelete/{row.Id}", g => g.Static("id", row.Id))
                    .WhileLoading(x => x.Element("native-action-link-status").SetText($"Deleting resident #{row.Id}..."))
                    .Response(r => r
                        .OnSuccess(x =>
                        {
                            x.Element("native-action-link-status").SetText($"Deleted resident #{row.Id}");
                            x.Dispatch("native-action-link-grid-refresh");
                        })
                        .OnError(400, x => x.Element("native-action-link-status").SetText($"Delete failed for resident #{row.Id}"))))
                .Else(x => x.Element("native-action-link-status").SetText($"Cancelled delete for resident #{row.Id}")))
                .CssClass("text-sm font-medium text-red-600 hover:text-red-700")
                .Attr("data-testid", $"native-action-link-{row.Id}")))
        </div>
    }
</native-vstack>
