@model ContentTypeModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@{
    var plan = Html.ReactivePlan<ContentTypeModel>();
}

<native-vstack gap="Base">
    <native-text color="Secondary">
        This partial was loaded via <code>Into</code> — HTML response injected with <code>ej.base.append</code>.
    </native-text>
    <native-grid cols="C2" gap="Base">
        @{ Html.InputField(plan, m => m.NativeValue, o => o.Label("Native Input (from partial)"))
           .NativeTextBox(b => b
               .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")); }
        @{ Html.InputField(plan, m => m.FusionAmount, o => o.Label("Fusion NumericTextBox (from partial)"))
           .FusionNumericTextBox(b => b
               .Min(0).Max(10000).Step(1)); }
    </native-grid>
    <p class="text-xs text-text-muted" id="partial-loaded-marker">Partial loaded successfully</p>
</native-vstack>
@Html.EJS().ScriptManager()
