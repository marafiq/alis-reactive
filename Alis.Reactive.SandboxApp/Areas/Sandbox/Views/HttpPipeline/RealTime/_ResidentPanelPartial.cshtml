@model ResidentPanelModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.SandboxApp.Hubs
@{
    ReactivePlan<ResidentPanelModel> plan = new ReactivePlan<ResidentPanelModel>();

    // Partial connects to the SAME hub as parent — runtime reuses the connection
    Html.On(plan, t => t.SignalR<ResidentStatusPayload>("/hubs/resident-status", "StatusChanged",
        (payload, p) =>
    {
        p.Element("panel-resident-name").SetText(payload, x => x.ResidentName);
        p.Element("panel-resident-status").SetText(payload, x => x.Status);
    }));
}

<native-card elevation="Flat">
    <native-card-body padding="Compact">
        <native-heading level="H3">Resident Panel (Partial)</native-heading>
        <native-text color="Secondary" size="Sm">
            This partial has its own plan with a SignalR trigger. The runtime
            reused the existing /hubs/resident-status connection — check the
            console for a single "connected" trace.
        </native-text>
        <native-divider />
        <native-grid cols="C2" gap="Sm">
            <div>
                <dt class="text-xs font-medium text-text-muted uppercase tracking-wide">Resident</dt>
                <dd id="panel-resident-name" class="mt-1 text-sm text-text-primary">—</dd>
            </div>
            <div>
                <dt class="text-xs font-medium text-text-muted uppercase tracking-wide">Status</dt>
                <dd id="panel-resident-status" class="mt-1 text-sm text-text-primary">—</dd>
            </div>
        </native-grid>
    </native-card-body>
</native-card>

@Html.RenderPlan(plan)
