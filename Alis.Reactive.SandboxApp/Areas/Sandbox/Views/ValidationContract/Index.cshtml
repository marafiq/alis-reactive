@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.ResidentModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@using Alis.Reactive.Fusion.Extensions
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Validation Contract — Scenario 1";
    var plan = Html.ReactivePlan<ResidentModel>();

    var careLevels = ((string[])ViewBag.CareLevels)
        .Select(c => new SelectListItem(c, c))
        .ToList();
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold tracking-tight">Scenario 1 — Single Page, All Fields</h1>
        <p class="mt-2 text-text-secondary">
            Mixed vendors (Native + Fusion), unconditional + conditional rules (truthy, falsy, eq, neq),
            equalTo cross-field, nested address, server error routing.
        </p>
    </div>

    <form id="resident-form" class="rounded-lg border border-border bg-white p-6 shadow-sm space-y-4">
        <h2 class="text-base font-semibold mb-2">Basic Information</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.Field("Name", true, m => m.Name, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Resident name")
            ); }

            @{ Html.Field("Email", true, m => m.Email, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("resident@care.com")
            ); }

            @{ Html.Field("Confirm Email", true, m => m.ConfirmEmail, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Confirm email")
            ); }

            @{ Html.Field("Care Level", true, m => m.CareLevel, expr =>
                Html.NativeDropDownFor(plan, expr)
                    .Items(careLevels)
                    .Placeholder("-- Select Care Level --")
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
            ); }
        </div>

        <h2 class="text-base font-semibold mb-2 mt-6">Veteran Status</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.Field("Veteran", false, m => m.IsVeteran, expr =>
                Html.NativeCheckBoxFor(plan, expr)
                    .CssClass("rounded border-border")
            ); }

            @{ Html.Field("Veteran ID", false, m => m.VeteranId, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("V12345")
            ); }
        </div>

        <h2 class="text-base font-semibold mb-2 mt-6">Care Details</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.Field("Memory Assessment Score", false, m => m.MemoryAssessmentScore, expr =>
                Html.NumericTextBoxFor(plan, expr)
                    .Placeholder("Score")
                    .CssClass("rounded-md border border-border")
                    .Render()
            ); }

            @{ Html.Field("Physician Name", false, m => m.PhysicianName, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Dr. Smith")
            ); }
        </div>

        <h2 class="text-base font-semibold mb-2 mt-6">Emergency Contact</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.Field("Has Emergency Contact", false, m => m.HasEmergencyContact, expr =>
                Html.NativeCheckBoxFor(plan, expr)
                    .CssClass("rounded border-border")
            ); }

            @{ Html.Field("Emergency Name", false, m => m.EmergencyName, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Contact name")
            ); }

            @{ Html.Field("Emergency Phone", false, m => m.EmergencyPhone, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("555-0123")
            ); }

            @{ Html.Field("Reason for No Contact", false, m => m.ReasonForNoContact, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Explain why no contact")
            ); }
        </div>

        <h2 class="text-base font-semibold mb-2 mt-6">Address</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @{ Html.Field("Street", true, m => m.Address.Street, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("123 Main St")
            ); }

            @{ Html.Field("City", true, m => m.Address.City, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("Springfield")
            ); }

            @{ Html.Field("Zip Code", true, m => m.Address.ZipCode, expr =>
                Html.NativeTextBoxFor(plan, expr)
                    .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                    .Placeholder("12345")
            ); }
        </div>

        <div class="mt-6 flex items-center gap-4">
            @(Html.NativeButton("submit-btn", "Submit Admission")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Post("/Sandbox/ValidationContract/Submit", g => g.IncludeAll())
                     .Validate<ResidentValidator>("resident-form")
                     .Response(r => r
                        .OnSuccess(s => s.Element("result").SetText("Admission saved"))
                        .OnError(400, e =>
                        {
                            e.ValidationErrors("resident-form");
                        }));
                }))

            <p id="result" class="text-sm text-text-muted"></p>
        </div>
    </form>
</div>

@Html.RenderPlan(plan)
