@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.ContentTypeModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.Fusion.Components
@using Alis.Reactive.Fusion.Extensions
@using Alis.Reactive.SandboxApp.Areas.Sandbox.Models
@{
    var plan = new ReactivePlan<ContentTypeModel>();
}

<div class="space-y-3">
    <p class="text-sm text-text-secondary">
        This partial was loaded via <code>Into</code> — HTML response injected with <code>ej.base.append</code>.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        @{ Html.Field("Native Input (from partial)", false, m => m.NativeValue, expr =>
            Html.NativeTextBoxFor(plan, expr).CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
        ); }
        @{ Html.Field("Fusion NumericTextBox (from partial)", false, m => m.FusionAmount, expr =>
            Html.NumericTextBoxFor(plan, expr)
                .Min(0).Max(10000).Step(1)
                .Render()
        ); }
    </div>
    <p class="text-xs text-text-muted" id="partial-loaded-marker">Partial loaded successfully</p>
</div>
@Html.EJS().ScriptManager()
