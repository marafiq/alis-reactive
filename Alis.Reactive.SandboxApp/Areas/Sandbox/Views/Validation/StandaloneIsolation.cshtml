@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.ValidationMergeHarnessModel
@using Alis.Reactive
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@using Alis.Reactive.SandboxApp.Areas.Sandbox.Models
@{
    ViewData["Title"] = "Validation Standalone Isolation";
    var plan = Html.ReactivePlan<ValidationMergeHarnessModel>();
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold tracking-tight">Validation BDD: Standalone Isolation</h1>
        <p class="mt-2 text-text-secondary">
            One root validation surface plus one standalone contact plan on the same page. The two must not bleed into each other.
        </p>
    </div>

    <section class="rounded-lg border border-border bg-white p-6 shadow-sm space-y-4">
        <div class="flex flex-wrap gap-3">
            @(Html.NativeButton("isolation-load-address-btn", "Load Address Partial")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Get("/Sandbox/Validation/IsolationAddressPartial")
                     .Response(r => r.OnSuccess(s =>
                     {
                         s.Into("isolation-address-container");
                         s.Element("isolation-address-status").SetText("Address partial loaded");
                     }));
                }))

            @(Html.NativeButton("isolation-load-contact-btn", "Load Standalone Contact")
                .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
                .Reactive(plan, evt => evt.Click, (args, p) =>
                {
                    p.Get("/Sandbox/Validation/IsolationContactPartial")
                     .Response(r => r.OnSuccess(s =>
                     {
                         s.Into("isolation-contact-container");
                         s.Element("isolation-contact-status").SetText("Standalone contact loaded");
                     }));
                }))
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 font-mono text-sm">
            <p id="isolation-address-status" class="text-text-muted">Address partial not loaded</p>
            <p id="isolation-contact-status" class="text-text-muted">Standalone contact not loaded</p>
        </div>

        <form id="isolation-parent-form" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @{ Html.Field("Name", true, m => m.Root.Name, expr =>
                    Html.NativeTextBoxFor(plan, expr)
                        .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                        .Placeholder("Parent name")
                ); }
                @{ Html.Field("Email", true, m => m.Root.Email, expr =>
                    Html.NativeTextBoxFor(plan, expr)
                        .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                        .Placeholder("parent@example.com")
                ); }
            </div>

            <div id="isolation-address-container" class="space-y-4"></div>
        </form>

        @(Html.NativeButton("isolation-save-parent-btn", "Save Parent Root")
            .CssClass("rounded-md bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800 transition-colors")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/SaveIsolationParent", g => g
                        .Include(m => m.Root.Name)
                        .Include(m => m.Root.Email)
                        .Include(m => m.Nested.Address!.Street)
                        .Include(m => m.Nested.Address!.City)
                        .Include(m => m.Nested.Address!.ZipCode))
                 .Validate<ValidationIsolationValidator>("isolation-parent-form")
                 .Response(r => r
                    .OnSuccess(s =>
                    {
                        s.Element("isolation-parent-result").SetText("Parent root saved");
                        s.Element("isolation-parent-result").AddClass("text-green-600");
                        s.Element("isolation-parent-result").RemoveClass("text-red-600");
                        s.Element("isolation-parent-result").RemoveClass("text-text-muted");
                    })
                    .OnError(400, e =>
                    {
                        e.Element("isolation-parent-result").SetText("Parent validation errors");
                        e.Element("isolation-parent-result").AddClass("text-red-600");
                        e.Element("isolation-parent-result").RemoveClass("text-green-600");
                        e.ValidationErrors("isolation-parent-form");
                    }));
            }))

        <p id="isolation-parent-result" class="font-mono text-sm text-text-muted">Not submitted yet</p>

        <div id="isolation-contact-container" class="space-y-4"></div>
    </section>
</div>

@Html.RenderPlan(plan)
