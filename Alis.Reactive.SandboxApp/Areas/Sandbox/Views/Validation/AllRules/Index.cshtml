@model ValidationShowcaseModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@{
    ViewData["Title"] = "Validation";
    var plan = Html.ReactivePlan<ValidationShowcaseModel>();
}

<native-vstack gap="Lg">
    <div>
        <native-heading level="H1">Validation Showcase</native-heading>
        <native-text color="Secondary">
            Each form uses a scoped validator that covers exactly its fields.
            Fail-closed: unenriched fields block, hidden fields validate to summary.
        </native-text>
    </div>

    <!-- Section 1: All Rule Types -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">1. All Rule Types</native-heading>
        <form id="all-rules-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.AllRules!.Name, o => o.Required().Label("Name"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Full name")); }
            @{ Html.InputField(plan, m => m.AllRules!.Email, o => o.Required().Label("Email"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("you@example.com")); }
            @{ Html.InputField(plan, m => m.AllRules!.Age, o => o.Label("Age"))
               .NativeTextBox(b => b
                   .Type("number")
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("0-120")); }
            @{ Html.InputField(plan, m => m.AllRules!.Phone, o => o.Label("Phone"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("123-456-7890")); }
            @{ Html.InputField(plan, m => m.AllRules!.Salary, o => o.Label("Salary"))
               .NativeTextBox(b => b
                   .Type("number")
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("0-500000")); }
            @{ Html.InputField(plan, m => m.AllRules!.Password, o => o.Label("Password"))
               .NativeTextBox(b => b
                   .Type("password")
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Min 8 chars")); }
        </form>
        @(Html.NativeButton("validate-all-btn", "Validate All")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/AllRules/ValidateClient")
                 .Validate<AllRulesFormValidator>("all-rules-form")
                 .Response(r => r.OnSuccess(s =>
                 {
                     s.Element("all-rules-result").SetText("All fields passed client-side validation!");
                     s.Element("all-rules-result").AddClass("text-green-600");
                     s.Element("all-rules-result").RemoveClass("text-text-muted");
                 }));
            }))
        <p id="all-rules-result" class="mt-3 text-sm text-text-muted">Click to validate</p>
    </native-card-body>
    </native-card>

    <!-- Section 2: Server 400 -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">2. Server Validation (400)</native-heading>
        <form id="server-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.Server!.Name, o => o.Required().Label("Name"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Leave empty")); }
            @{ Html.InputField(plan, m => m.Server!.Email, o => o.Required().Label("Email"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Leave empty")); }
        </form>
        @(Html.NativeButton("server-save-btn", "Save (Server Validate)")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/AllRules/Save", g => g.Include(m => m.Server!.Name).Include(m => m.Server!.Email))
                 .Validate<ServerFormValidator>("server-form")
                 .Response(r => r
                    .OnSuccess(s =>
                    {
                        s.Element("server-result").SetText("Server accepted!");
                        s.Element("server-result").AddClass("text-green-600");
                    })
                    .OnError(400, e =>
                    {
                        e.Element("server-result").SetText("Server returned validation errors");
                        e.Element("server-result").AddClass("text-red-600");
                        e.ValidationErrors("server-form");
                    }));
            }))
        <p id="server-result" class="mt-3 text-sm text-text-muted">Not submitted yet</p>
    </native-card-body>
    </native-card>

    <!-- Section 3: Conditional -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">3. Conditional Rules</native-heading>
        <form id="conditional-form" class="space-y-4 mb-4">
            @{ Html.InputField(plan, m => m.Conditional!.IsEmployed, o => o.Label("Is Employed"))
               .NativeCheckBox(b => b
                   .CssClass("h-4 w-4 rounded border-border text-accent")); }
            @{ Html.InputField(plan, m => m.Conditional!.JobTitle, o => o.Label("Job Title"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Required when employed")); }
        </form>
        @(Html.NativeButton("conditional-validate-btn", "Validate Conditional")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/AllRules/ValidateClient")
                 .Validate<ConditionalFormValidator>("conditional-form")
                 .Response(r => r.OnSuccess(s =>
                 {
                     s.Element("conditional-result").SetText("Conditional validation passed!");
                     s.Element("conditional-result").AddClass("text-green-600");
                 }));
            }))
        <p id="conditional-result" class="mt-3 text-sm text-text-muted">Click to validate</p>
    </native-card-body>
    </native-card>

    <!-- Section 4: Hidden Fields -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">4. Hidden Fields</native-heading>
        <form id="hidden-fields-form" class="space-y-4 mb-4">
            @{ Html.InputField(plan, m => m.Hidden!.Name, o => o.Required().Label("Name (always visible)"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Required")); }
            @{ Html.InputField(plan, m => m.Hidden!.ShowExtras, o => o.Label("Show Extra Fields"))
               .NativeCheckBox(b => b
                   .CssClass("h-4 w-4 rounded border-border text-accent")
                   .Reactive(plan, evt => evt.Changed, (args, p) =>
                   {
                       p.When(args, a => a.Checked).Truthy()
                        .Then(t => t.Element("hf_extras").Show())
                        .Else(e => e.Element("hf_extras").Hide());
                   })); }
            <div id="hf_extras" hidden class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                @{ Html.InputField(plan, m => m.Hidden!.Phone, o => o.Label("Phone (hidden)"))
                   .NativeTextBox(b => b
                       .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                       .Placeholder("123-456-7890")); }
                @{ Html.InputField(plan, m => m.Hidden!.Salary, o => o.Label("Salary (hidden)"))
                   .NativeTextBox(b => b
                       .Type("number")
                       .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                       .Placeholder("0-500000")); }
            </div>
        </form>
        @(Html.NativeButton("hidden-validate-btn", "Validate Hidden Form")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 mr-2")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/AllRules/ValidateClient")
                 .Validate<HiddenFieldsFormValidator>("hidden-fields-form")
                 .Response(r => r.OnSuccess(s =>
                 {
                     s.Element("hidden-result").SetText("Validation passed!");
                     s.Element("hidden-result").AddClass("text-green-600");
                 }));
            }))
        @(Html.NativeButton("hidden-submit-btn", "Submit Profile")
            .CssClass("rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/AllRules/SaveProfile", g => g
                    .Include(m => m.Hidden!.Name)
                    .Include(m => m.Hidden!.Phone)
                    .Include(m => m.Hidden!.Salary))
                 .Validate<HiddenFieldsFormValidator>("hidden-fields-form")
                 .Response(r => r
                    .OnSuccess(s =>
                    {
                        s.Element("hidden-result").SetText("Profile saved!");
                        s.Element("hidden-result").AddClass("text-green-600");
                    })
                    .OnError(400, e =>
                    {
                        e.Element("hidden-result").SetText("Server validation errors");
                        e.Element("hidden-result").AddClass("text-red-600");
                        e.ValidationErrors("hidden-fields-form");
                    }));
            }))
        <p id="hidden-result" class="mt-3 text-sm text-text-muted">Click to validate or submit</p>
    </native-card-body>
    </native-card>

    <!-- Section 5: DB Validation -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">5. Fake DB Validation (ProblemDetails 400)</native-heading>
        <form id="db-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            @{ Html.InputField(plan, m => m.Db!.Name, o => o.Required().Label("Name"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Try 'admin'")); }
            @{ Html.InputField(plan, m => m.Db!.Email, o => o.Required().Label("Email"))
               .NativeTextBox(b => b
                   .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                   .Placeholder("Try 'taken@test.com'")); }
        </form>
        @(Html.NativeButton("db-save-btn", "Save with DB Check")
            .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90")
            .Reactive(plan, evt => evt.Click, (args, p) =>
            {
                p.Post("/Sandbox/Validation/AllRules/SaveWithDbCheck", g => g.Include(m => m.Db!.Name).Include(m => m.Db!.Email))
                 .Validate<DbFormValidator>("db-form")
                 .Response(r => r
                    .OnSuccess(s =>
                    {
                        s.Element("db-result").SetText("Saved to database!");
                        s.Element("db-result").AddClass("text-green-600");
                    })
                    .OnError(400, e =>
                    {
                        e.Element("db-result").SetText("Database validation failed");
                        e.Element("db-result").AddClass("text-red-600");
                        e.ValidationErrors("db-form");
                    }));
            }))
        <p id="db-result" class="mt-3 text-sm text-text-muted">Not submitted yet</p>
    </native-card-body>
    </native-card>

    <!-- Plan JSON -->
    <native-card>
    <native-card-body>
        <native-heading level="H2">Plan JSON</native-heading>
        <pre class="rounded-md bg-slate-900 text-emerald-400 p-4 font-mono text-xs overflow-x-auto"><code id="plan-json">@Html.Raw(plan.RenderFormatted())</code></pre>
    </native-card-body>
    </native-card>
</native-vstack>

@Html.RenderPlan(plan)
