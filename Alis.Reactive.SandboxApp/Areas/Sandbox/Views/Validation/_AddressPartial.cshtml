@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.ValidationShowcaseModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@{
    var plan = Html.ResolvePlan<ValidationShowcaseModel>();
}
<!-- Partial: Address fields loaded dynamically -->
<div id="address-section" class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    @{ Html.Field("Street *", false, m => m.Nested!.Address!.Street, expr =>
        Html.NativeTextBoxFor(plan, expr).CssClass("rounded-md border border-border px-3 py-1.5 text-sm").Placeholder("Street address")
    ); }
    @{ Html.Field("City *", false, m => m.Nested!.Address!.City, expr =>
        Html.NativeTextBoxFor(plan, expr).CssClass("rounded-md border border-border px-3 py-1.5 text-sm").Placeholder("City")
    ); }
    @{ Html.Field("Zip Code", false, m => m.Nested!.Address!.ZipCode, expr =>
        Html.NativeTextBoxFor(plan, expr).CssClass("rounded-md border border-border px-3 py-1.5 text-sm").Placeholder("Min 5 chars")
    ); }
</div>

@Html.RenderPlan(plan)
