@model ResidentModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@{
    var plan = Html.ResolvePlan<ResidentModel>();
}

<native-grid cols="C2" gap="Base">
    @{ Html.InputField(plan, m => m.HasEmergencyContact, o => o.Label("Has Emergency Contact"))
       .NativeCheckBox(b => b
           .CssClass("rounded border-border")); }

    @{ Html.InputField(plan, m => m.EmergencyName, o => o.Label("Emergency Name"))
       .NativeTextBox(b => b
           .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
           .Placeholder("Contact name")); }

    @{ Html.InputField(plan, m => m.EmergencyPhone, o => o.Label("Emergency Phone"))
       .NativeTextBox(b => b
           .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
           .Placeholder("555-0123")
           .Reactive(plan, evt => evt.Changed, (args, p) =>
           {
               p.Element("phone-format-status").SetText("Phone updated");
           })); }

    @{ Html.InputField(plan, m => m.ReasonForNoContact, o => o.Label("Reason for No Contact"))
       .NativeTextBox(b => b
           .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
           .Placeholder("Explain why no contact")); }
</native-grid>

<div class="mt-2">
    <span id="phone-format-status" class="text-sm text-text-muted"></span>
</div>

@Html.RenderPlan(plan)
