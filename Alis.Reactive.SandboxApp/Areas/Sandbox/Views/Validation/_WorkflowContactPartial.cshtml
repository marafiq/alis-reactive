@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.ContactFormModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@{
    var plan = Html.ReactivePlan<ContactFormModel>();
}

<form id="workflow-contact-form" class="space-y-4 rounded-md border border-border p-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @{ Html.Field("Name", true, m => m.Name, expr =>
            Html.NativeTextBoxFor(plan, expr)
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                .Placeholder("Workflow Contact")
        ); }
        @{ Html.Field("Email", true, m => m.Email, expr =>
            Html.NativeTextBoxFor(plan, expr)
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                .Placeholder("workflow.contact@example.com")
        ); }
    </div>

    @{ Html.Field("Message", true, m => m.Message, expr =>
        Html.NativeTextBoxFor(plan, expr)
            .CssClass("rounded-md border border-border px-3 py-1.5 text-sm w-full")
            .Placeholder("Need delivery confirmation tomorrow.")
    ); }

    @(Html.NativeButton("workflow-send-contact-btn", "Send Workflow Contact")
        .CssClass("rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors")
        .Reactive(plan, evt => evt.Click, (args, p) =>
        {
            p.Post("/Sandbox/Validation/SendWorkflowContact", g => g
                    .Include(m => m.Name)
                    .Include(m => m.Email)
                    .Include(m => m.Message))
             .Validate<ContactFormValidator>("workflow-contact-form")
             .Response(r => r
                .OnSuccess(s =>
                {
                    s.Element("workflow-contact-result").SetText("Workflow contact sent");
                    s.Element("workflow-contact-result").AddClass("text-green-600");
                    s.Element("workflow-contact-result").RemoveClass("text-red-600");
                    s.Element("workflow-contact-result").RemoveClass("text-text-muted");
                })
                .OnError(400, e =>
                {
                    e.Element("workflow-contact-result").SetText("Workflow contact validation errors");
                    e.Element("workflow-contact-result").AddClass("text-red-600");
                    e.Element("workflow-contact-result").RemoveClass("text-green-600");
                    e.ValidationErrors("workflow-contact-form");
                }));
        }))

    <p id="workflow-contact-result" class="font-mono text-sm text-text-muted">Not submitted yet</p>
</form>

@Html.RenderPlan(plan)
