@model Alis.Reactive.SandboxApp.Areas.Sandbox.Models.ValidationMergeHarnessModel
@using Alis.Reactive.Native.Extensions
@using Alis.Reactive.Native.Components
@{
    var plan = Html.ResolvePlan<ValidationMergeHarnessModel>();
}

<div class="space-y-3 rounded-md border border-border p-4">
    <p id="workflow-address-version" class="font-mono text-sm text-text-muted">Address partial v1</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        @{ Html.Field("Street", true, m => m.Nested.Address!.Street, expr =>
            Html.NativeTextBoxFor(plan, expr)
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                .Placeholder("42 Wallaby Way")
        ); }
        @{ Html.Field("City", true, m => m.Nested.Address!.City, expr =>
            Html.NativeTextBoxFor(plan, expr)
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                .Placeholder("Sydney")
        ); }
        @{ Html.Field("Zip Code", false, m => m.Nested.Address!.ZipCode, expr =>
            Html.NativeTextBoxFor(plan, expr)
                .CssClass("rounded-md border border-border px-3 py-1.5 text-sm")
                .Placeholder("2000")
        ); }
    </div>
</div>

@Html.RenderPlan(plan)
