<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — Alis.Reactive Sandbox</title>
    <link rel="stylesheet" href="https://cdn.syncfusion.com/ej2/32.2.8/tailwind3.css"/>
    <link rel="stylesheet" href="~/css/alis-modern-tailwind.css" asp-append-version="true"/>
</head>
<body class="h-full bg-surface text-text-primary antialiased">

<div class="min-h-full flex flex-col">
    <header class="border-b border-border bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-14">
                <a asp-controller="Home" asp-action="Index"
                   class="text-lg font-semibold tracking-tight text-accent">
                    Alis.Reactive
                </a>
                <nav class="flex gap-6 text-sm font-medium">
                    <a asp-controller="Home" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Home</a>
                    <a asp-area="Sandbox" asp-controller="Events" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Events</a>
                    <a asp-area="Sandbox" asp-controller="Payload" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Payload</a>
                    <a asp-area="Sandbox" asp-controller="Conditions" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Conditions</a>
                    <a asp-area="Sandbox" asp-controller="PlaygroundSyntax" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Playground</a>
                    <a asp-area="Sandbox" asp-controller="PlaygroundSyntax" asp-action="ReactiveConditions"
                       class="text-text-secondary hover:text-text-primary transition-colors">Reactive Conditions</a>
                    <a asp-area="Sandbox" asp-controller="Validation" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Validation</a>
                    <a asp-area="Sandbox" asp-controller="Architecture" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Architecture</a>
                    <a asp-area="Sandbox" asp-controller="ContentType" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">Content Type</a>
                    <a asp-area="Sandbox" asp-controller="NumericTextBox" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">NumericTextBox</a>
                    <a asp-area="Sandbox" asp-controller="DropDownList" asp-action="Index"
                       class="text-text-secondary hover:text-text-primary transition-colors">DropDownList</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="flex-1">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            @RenderBody()
        </div>
    </main>

    <footer class="border-t border-border bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <p class="text-xs text-text-muted">&copy; 2026 Alis.Reactive Sandbox</p>
        </div>
    </footer>
</div>

<script src="https://cdn.syncfusion.com/ej2/32.2.8/dist/ej2.min.js"></script>
@Html.EJS().ScriptManager()
@await RenderSectionAsync("Scripts", required: false)

@Html.FusionConfirmDialog()
<script type="module" src="~/js/alis-reactive.js" asp-append-version="true"></script>
</body>
</html>
