@{
    ViewData["Title"] = "Home";
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold tracking-tight">Alis.Reactive Sandbox</h1>
        <p class="mt-2 text-text-secondary">
            Proving ground for the reactive descriptor pattern.
            Each feature is a self-contained demo with live behavior and source code.
        </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a asp-area="Sandbox" asp-controller="Events" asp-action="Index"
           class="group block rounded-lg border border-border bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
            <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                Events &amp; Dispatch
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                Custom event triggers, dispatch commands, payload flow, and event chaining.
            </p>
        </a>

        <a asp-area="Sandbox" asp-controller="Payload" asp-action="Index"
           class="group block rounded-lg border border-border bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
            <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                Payload
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                Event payload structure and typed field resolution across vendors.
            </p>
        </a>

        <a asp-area="Sandbox" asp-controller="Conditions" asp-action="Index"
           class="group block rounded-lg border border-border bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
            <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                Conditions
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                All 20 operators, AND/OR composition, NOT inversion, Confirm dialog, per-action When guards.
            </p>
        </a>

        <a asp-area="Sandbox" asp-controller="PlaygroundSyntax" asp-action="Index"
           class="group block rounded-lg border border-border bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
            <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                Playground Syntax
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                Html.Field() wrapping, .Reactive() on Fusion and Native builders, cross-vendor custom events, nested properties.
            </p>
        </a>

        <a asp-area="Sandbox" asp-controller="PlaygroundSyntax" asp-action="ReactiveConditions"
           class="group block rounded-lg border border-border bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
            <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                Reactive Conditions
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                Conditions inside .Reactive() with Html.Field(), cross-vendor mutations, nested Component&lt;T&gt;() targeting.
            </p>
        </a>

        <a asp-area="Sandbox" asp-controller="Http" asp-action="Index"
           class="group block rounded-lg border border-border bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
            <h2 class="text-base font-semibold group-hover:text-accent transition-colors">
                HTTP Requests
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                GET, POST with gather, chained sequential, and parallel concurrent requests with response routing.
            </p>
        </a>
    </div>
</div>
