{
  "private": true,
  "scripts": {
    "build": "esbuild Alis.Reactive.SandboxApp/Scripts/auto-boot.ts --bundle --outfile=Alis.Reactive.SandboxApp/wwwroot/js/alis-reactive.js --format=esm --minify",
    "build:css": "npx @tailwindcss/cli -i Alis.Reactive.SandboxApp/Styles/app.css -o Alis.Reactive.SandboxApp/wwwroot/css/alis-modern-tailwind.css --minify",
    "build:test-widget": "esbuild Alis.Reactive.SandboxApp/Scripts/test-widget.ts --bundle --format=iife --outfile=Alis.Reactive.SandboxApp/wwwroot/js/test-widget.js",
    "build:all": "npm run build && npm run build:test-widget && npm run build:css",
    "watch": "esbuild Alis.Reactive.SandboxApp/Scripts/auto-boot.ts --bundle --outfile=Alis.Reactive.SandboxApp/wwwroot/js/alis-reactive.js --format=esm --watch",
    "watch:css": "npx @tailwindcss/cli -i Alis.Reactive.SandboxApp/Styles/app.css -o Alis.Reactive.SandboxApp/wwwroot/css/alis-modern-tailwind.css --watch",
    "typecheck": "tsc --project Alis.Reactive.SandboxApp/Scripts/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "esbuild": "^0.25.0",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
